---
// src/pages/terms.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Service" description="Terms of service and financial modeling disclaimers for OmniValuation.">
  <div class="card-glass content-container">
    <h1>Terms of Service</h1>
    <p class="last-updated">Last Updated: June 13, 2026</p>

    <section>
      <h2>1. Valuation Disclaimer</h2>
      <p>Calculations generated by our software platforms and tax tools represent model estimations for comparative purposes only. These values do not constitute formal legal, corporate, or financial advisory determinations.</p>
    </section>

    <section>
      <h2>2. Permitted Use</h2>
      <p>Users are granted permission to run calculators and copy comparative outputs for internal research. Programmatic scraping or denial of service targeting our Cloudflare edge endpoints is strictly prohibited.</p>
    </section>
  </div>

  <style>
    .content-container {
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 28px;
    }

    .last-updated {
      color: hsl(var(--text-secondary));
      font-style: italic;
      font-size: 0.9rem;
      border-bottom: 1px solid hsl(var(--border));
      padding-bottom: 16px;
    }

    section h2 {
      font-size: 1.25rem;
      margin-bottom: 12px;
      color: #fff;
    }

    section p {
      color: hsl(var(--text-secondary));
    }
  </style>
</BaseLayout>
