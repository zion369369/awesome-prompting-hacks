---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import prompts from '../data/scraped_prompts.json';
import fs from 'fs';
import path from 'path';

// Write search index at build time
const searchIndexPathPublic = path.join(process.cwd(), 'public/search-index.json');
const searchIndexPathDocs = path.join(process.cwd(), 'docs/search-index.json');
const indexData = prompts.map(p => ({
  title: p.title,
  slug: p.slug,
  category: p.category,
  tags: p.tags,
  imageUrl: p.imageUrl,
  promptExcerpt: p.prompt.substring(0, 150)
}));

const publicDir = path.dirname(searchIndexPathPublic);
if (!fs.existsSync(publicDir)) {
  fs.mkdirSync(publicDir, { recursive: true });
}
fs.writeFileSync(searchIndexPathPublic, JSON.stringify(indexData));

const docsDir = path.dirname(searchIndexPathDocs);
if (!fs.existsSync(docsDir)) {
  fs.mkdirSync(docsDir, { recursive: true });
}
fs.writeFileSync(searchIndexPathDocs, JSON.stringify(indexData));

// Extract unique popular tags for quick filter buttons
const tagCounts = {};
prompts.forEach((item) => {
  item.tags.forEach((tag) => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});

const popularTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10)
  .map(([tag]) => tag);

const pageTitle = "Awesome Prompting Hacks - Free Production-Grade AI Prompts";
const pageDesc = "High-performance curated prompt templates for Midjourney, ChatGPT, Gemini, and Claude. Copy templates and optimize your workflows instantly.";

// Generate structured JSON-LD for WebSite
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Awesome Prompting Hacks",
  "url": Astro.url.origin,
  "description": pageDesc,
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${Astro.url.origin}/?search={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const buildVersion = Date.now().toString();
---

<BaseLayout title={pageTitle} description={pageDesc} jsonLd={jsonLd}>
  <div class="aquarium-hero">
    <canvas id="aquarium-canvas"></canvas>
    <div class="aquarium-content">
      <h1 class="aquarium-title">Awesome Prompting Hacks</h1>
      <p class="aquarium-subtitle">Discover, copy, and refine production-grade prompt templates. Optimized for execution with the Hello Prompting extension.</p>
      
      <div class="aquarium-scroll-tag">
        <span>Scroll down & dive in</span>
        <svg class="scroll-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <polyline points="19 12 12 19 5 12"></polyline>
        </svg>
      </div>
    </div>
  </div>

  <div class="search-section">
    <!-- Client-Side Instant Search Filter -->
    <div class="search-box card-glass">
      <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input type="text" id="prompt-search" placeholder="Search prompts by keyword, tags, style e.g. '3D', 'cat', 'pixar'..." class="input-field search-input" />
    </div>

    <!-- Quick filter tags -->
    {popularTags.length > 0 && (
      <div class="quick-tags">
        <button class="tag-filter-btn active" data-tag="all">All Styles</button>
        {popularTags.map((tag) => (
          <button class="tag-filter-btn" data-tag={tag}>#{tag}</button>
        ))}
      </div>
    )}
  </div>

  <!-- Prompts Gallery Grid -->
  <div class="gallery-grid" id="prompts-gallery">
    {prompts.slice(0, 48).map((item) => {
      const keywords = `${item.title} ${item.prompt} ${item.tags.join(' ')}`.toLowerCase();
      return (
        <a href={`${baseUrl}prompts/${item.slug}`} class="prompt-card card-glass" data-keywords={keywords} data-tags={JSON.stringify(item.tags)}>
          {item.imageUrl && (
            <div class="card-image-wrap">
              <img src={item.imageUrl} alt={item.title} class="card-image" loading="lazy" />
              <div class="card-image-overlay"></div>
            </div>
          )}
          
          <div class="card-content">
            <span class="card-category">{item.category.toUpperCase()}</span>
            <h3 class="card-title">{item.title}</h3>
            
            <div class="card-tags">
              {item.tags.slice(0, 3).map((tag) => (
                <span class="card-tag">#{tag}</span>
              ))}
              {item.tags.length > 3 && (
                <span class="card-tag-more">+{item.tags.length - 3}</span>
              )}
            </div>

            <div class="card-footer">
              <span class="action-text">View Prompt</span>
              <svg class="action-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </div>
          </div>
        </a>
      );
    })}
  </div>

  <!-- No Results State -->
  <div id="no-results" class="no-results card-glass" style="display: none;">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="no-results-icon">
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      <line x1="8" y1="11" x2="14" y2="11"></line>
    </svg>
    <h3>No prompts found</h3>
    <p>Try refining your search query or choosing another style filter.</p>
  </div>

  <style is:global>
    .aquarium-hero {
      position: relative;
      width: 100vw;
      left: 50%;
      right: 50%;
      margin-left: -50vw;
      margin-right: -50vw;
      height: 60vh;
      min-height: 400px;
      overflow: hidden;
      background: linear-gradient(180deg, #090d16 0%, #0d182e 60%, #02050b 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      border-bottom: 1px solid hsl(var(--border));
    }

    #aquarium-canvas {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
      pointer-events: auto;
    }

    .aquarium-content {
      position: relative;
      z-index: 2;
      text-align: center;
      padding: 24px;
      max-width: 800px;
      color: #ffffff;
      pointer-events: none;
    }

    .aquarium-title {
      font-size: 3.75rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 16px;
      line-height: 1.1;
      background: linear-gradient(135deg, #ffffff 30%, #38bdf8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .aquarium-subtitle {
      font-size: 1.25rem;
      color: rgba(255, 255, 255, 0.85);
      margin-bottom: 32px;
      line-height: 1.5;
      text-shadow: 0 4px 12px rgba(0,0,0,0.5);
    }

    .aquarium-scroll-tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      padding: 8px 18px;
      border-radius: 9999px;
      font-size: 0.9rem;
      font-weight: 500;
      color: #ffffff;
      box-shadow: 0 8px 24px rgba(0,0,0,0.25);
      animation: float-tag 3s ease-in-out infinite;
    }

    .scroll-arrow {
      animation: bounce-arrow 1.5s ease-in-out infinite;
    }

    @keyframes float-tag {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }

    @keyframes bounce-arrow {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(3px); }
    }

    /* Search section container */
    .search-section {
      max-width: 1280px;
      margin: -60px auto 48px auto;
      padding: 0 24px;
      display: flex;
      flex-direction: column;
      align-items: center;
      position: relative;
      z-index: 3;
    }

    /* Search bar styling */
    .search-box {
      max-width: 650px;
      width: 100%;
      padding: 8px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      background: #ffffff;
      border-radius: 14px;
      margin-top: 8px;
      border: 1px solid hsl(var(--border));
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
    }

    .search-icon {
      color: hsl(var(--text-muted));
    }

    .search-input {
      border: none;
      background: transparent;
      padding: 10px 0;
      font-size: 1.1rem;
      width: 100%;
      color: hsl(var(--text-primary));
    }

    .search-input:focus {
      outline: none;
      box-shadow: none;
      border: none;
    }

    /* Quick Filter Tags */
    .quick-tags {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
      margin-top: 16px;
      max-width: 800px;
    }

    .tag-filter-btn {
      background: #ffffff;
      border: 1px solid hsl(var(--border));
      color: hsl(var(--text-secondary));
      padding: 6px 14px;
      border-radius: 9999px;
      font-family: inherit;
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
      transition: var(--transition-smooth);
    }

    .tag-filter-btn:hover {
      background: hsl(var(--bg-surface));
      color: hsl(var(--text-primary));
      border-color: rgba(0, 0, 0, 0.1);
    }

    .tag-filter-btn.active {
      background: rgba(37, 99, 235, 0.08);
      color: hsl(var(--primary));
      border-color: rgba(37, 99, 235, 0.2);
    }

    /* Grid Gallery */
    .gallery-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px;
    }

    @media (min-width: 640px) {
      .gallery-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 992px) {
      .gallery-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    /* Card styling */
    .prompt-card {
      display: flex;
      flex-direction: column;
      padding: 0;
      overflow: hidden;
      text-decoration: none;
      transition: var(--transition-smooth);
      background: #ffffff;
      border: 1px solid hsl(var(--border));
    }

    .prompt-card:hover {
      transform: translateY(-4px);
      border-color: hsl(var(--primary));
      box-shadow: 0 12px 36px rgba(37, 99, 235, 0.08);
    }

    .card-image-wrap {
      position: relative;
      width: 100%;
      height: 200px;
      overflow: hidden;
      background: rgba(0, 0, 0, 0.02);
    }

    .card-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: var(--transition-smooth);
    }

    .prompt-card:hover .card-image {
      transform: scale(1.04);
    }

    .card-image-overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(to bottom, transparent 60%, rgba(0, 0, 0, 0.02));
    }

    .card-content {
      padding: 24px;
      display: flex;
      flex-direction: column;
      flex-grow: 1;
    }

    .card-category {
      font-size: 0.75rem;
      font-weight: 700;
      color: hsl(var(--primary));
      letter-spacing: 0.05em;
      margin-bottom: 8px;
    }

    .card-title {
      font-size: 1.25rem;
      font-weight: 600;
      color: hsl(var(--text-primary));
      line-height: 1.3;
      margin-bottom: 12px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      height: 3.25rem;
    }

    .card-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 24px;
    }

    .card-tag {
      background: hsl(var(--bg-surface));
      border: 1px solid hsl(var(--border));
      color: hsl(var(--text-secondary));
      font-size: 0.75rem;
      padding: 2px 8px;
      border-radius: 4px;
    }

    .card-tag-more {
      background: rgba(0, 0, 0, 0.04);
      color: hsl(var(--text-muted));
      font-size: 0.75rem;
      padding: 2px 6px;
      border-radius: 4px;
      font-weight: 600;
    }

    .card-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: auto;
      border-top: 1px solid hsl(var(--border));
      padding-top: 16px;
    }

    .action-text {
      font-size: 0.9rem;
      font-weight: 600;
      color: hsl(var(--text-secondary));
      transition: var(--transition-smooth);
    }

    .action-icon {
      color: hsl(var(--text-muted));
      transition: var(--transition-smooth);
    }

    .prompt-card:hover .action-text {
      color: hsl(var(--primary));
    }

    .prompt-card:hover .action-icon {
      color: hsl(var(--primary));
      transform: translateX(3px);
    }

    /* No Results */
    .no-results {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 48px;
      gap: 12px;
      margin-top: 24px;
      border: 1px solid hsl(var(--border));
    }

    .no-results-icon {
      color: hsl(var(--text-muted));
    }

    .no-results h3 {
      color: hsl(var(--text-primary));
      font-size: 1.35rem;
    }

    .no-results p {
      color: hsl(var(--text-secondary));
      font-size: 0.95rem;
    }
  </style>

  <!-- Instant Search & Category Filter Script -->
  <script is:inline define:vars={{ baseUrl, buildVersion }}>
    let searchIndex = null;
    const searchInput = document.getElementById('prompt-search');
    const filterButtons = document.querySelectorAll('.tag-filter-btn');
    const gallery = document.getElementById('prompts-gallery');
    const noResults = document.getElementById('no-results');

    // Keep initial HTML to restore if search/filter is cleared
    const initialHtml = gallery ? gallery.innerHTML : '';

    let activeTag = 'all';
    let searchQuery = '';

    function escapeHtml(str) {
      if (!str) return '';
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    async function loadSearchIndex() {
      if (searchIndex) return searchIndex;
      try {
        const res = await fetch(`${baseUrl}search-index.json?v=${buildVersion}`);
        searchIndex = await res.json();
        return searchIndex;
      } catch (err) {
        console.error('Failed to load search index:', err);
        return [];
      }
    }

    async function filterGallery() {
      if (searchQuery === '' && activeTag === 'all') {
        if (gallery) gallery.innerHTML = initialHtml;
        if (noResults) noResults.style.display = 'none';
        return;
      }

      const index = await loadSearchIndex();
      let visibleCount = 0;
      let html = '';

      for (let i = 0; i < index.length; i++) {
        const item = index[i];
        
        // Search matches query
        const matchesQuery = searchQuery === '' || 
          item.title.toLowerCase().includes(searchQuery) ||
          item.category.toLowerCase().includes(searchQuery) ||
          item.tags.some(tag => tag.toLowerCase().includes(searchQuery)) ||
          item.promptExcerpt.toLowerCase().includes(searchQuery);

        const matchesTag = activeTag === 'all' || item.tags.includes(activeTag);

        if (matchesQuery && matchesTag) {
          visibleCount++;
          html += `
            <a href="${baseUrl}prompts/${item.slug}" class="prompt-card card-glass">
              ${item.imageUrl ? `
                <div class="card-image-wrap">
                  <img src="${item.imageUrl}" alt="${escapeHtml(item.title)}" class="card-image" loading="lazy" />
                  <div class="card-image-overlay"></div>
                </div>
              ` : ''}
              <div class="card-content">
                <span class="card-category">${escapeHtml(item.category.toUpperCase())}</span>
                <h3 class="card-title">${escapeHtml(item.title)}</h3>
                <div class="card-tags">
                  ${item.tags.slice(0, 3).map(tag => `<span class="card-tag">#${escapeHtml(tag)}</span>`).join('')}
                  ${item.tags.length > 3 ? `<span class="card-tag-more">+${item.tags.length - 3}</span>` : ''}
                </div>
                <div class="card-footer">
                  <span class="action-text">View Prompt</span>
                  <svg class="action-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </div>
              </div>
            </a>
          `;
        }
      }

      if (gallery) gallery.innerHTML = html;
      if (noResults) {
        noResults.style.display = visibleCount === 0 ? 'flex' : 'none';
      }
    }

    // Prefetch search index on page load
    loadSearchIndex();

    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = e.target.value.toLowerCase().trim();
        filterGallery();
      });
    }

    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterButtons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');

        activeTag = btn.getAttribute('data-tag') || 'all';
        filterGallery();
      });
    });
  </script>

  <!-- 3D Live Animated Aquarium Canvas Script -->
  <script is:inline>
    (function() {
      const canvas = document.getElementById('aquarium-canvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      
      let width = 0;
      let height = 0;
      
      function resize() {
        const rect = canvas.getBoundingClientRect();
        width = rect.width;
        height = rect.height;
        canvas.width = width * window.devicePixelRatio;
        canvas.height = height * window.devicePixelRatio;
        ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
      }
      
      window.addEventListener('resize', resize);
      resize();

      // Vector Fish Drawing Helper
      function drawFish(ctx, x, y, size, angle, color, tailWiggle, isFacingLeft) {
        ctx.save();
        ctx.translate(x, y);
        ctx.rotate(angle);
        if (isFacingLeft) {
          ctx.scale(-1, 1);
        }
        
        // Body Gradient (adds 3D roundness)
        const grad = ctx.createRadialGradient(size * 0.2, -size * 0.1, size * 0.1, 0, 0, size);
        grad.addColorStop(0, '#ffffff');
        grad.addColorStop(0.3, color.body || '#ff7e33');
        grad.addColorStop(1, color.shading || '#992200');

        // Tail fin (wagging)
        ctx.save();
        ctx.translate(-size * 0.85, 0);
        ctx.rotate(Math.sin(tailWiggle) * 0.4);
        
        const tailGrad = ctx.createLinearGradient(0, 0, -size * 0.6, 0);
        tailGrad.addColorStop(0, color.body || '#ff7e33');
        tailGrad.addColorStop(1, color.tail || '#ff3b3b');
        ctx.fillStyle = tailGrad;
        
        ctx.beginPath();
        ctx.moveTo(0, 0);
        ctx.quadraticCurveTo(-size * 0.4, -size * 0.5, -size * 0.6, -size * 0.4);
        ctx.quadraticCurveTo(-size * 0.35, 0, -size * 0.6, size * 0.4);
        ctx.quadraticCurveTo(-size * 0.4, size * 0.5, 0, 0);
        ctx.closePath();
        ctx.fill();
        ctx.restore();

        // Dorsal fin (top)
        const finGrad = ctx.createLinearGradient(0, -size * 0.35, 0, 0);
        finGrad.addColorStop(0, color.tail || '#ff3b3b');
        finGrad.addColorStop(1, color.body || '#ff7e33');
        ctx.fillStyle = finGrad;
        ctx.beginPath();
        ctx.moveTo(-size * 0.4, -size * 0.3);
        ctx.quadraticCurveTo(-size * 0.1, -size * 0.7, size * 0.2, -size * 0.25);
        ctx.quadraticCurveTo(-size * 0.1, -size * 0.2, -size * 0.4, -size * 0.3);
        ctx.closePath();
        ctx.fill();

        // Pectoral fin (bottom)
        ctx.beginPath();
        ctx.moveTo(-size * 0.2, size * 0.25);
        ctx.quadraticCurveTo(-size * 0.3, size * 0.5, -size * 0.05, size * 0.45);
        ctx.quadraticCurveTo(0, size * 0.25, -size * 0.2, size * 0.25);
        ctx.closePath();
        ctx.fill();

        // Main body
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.ellipse(0, 0, size, size * 0.42, 0, 0, Math.PI * 2);
        ctx.fill();

        // Stripes
        if (color.stripes === 'clownfish') {
          ctx.fillStyle = '#ffffff';
          ctx.beginPath();
          ctx.ellipse(-size * 0.1, 0, size * 0.15, size * 0.4, 0, 0, Math.PI * 2);
          ctx.fill();
          ctx.beginPath();
          ctx.ellipse(size * 0.3, 0, size * 0.1, size * 0.35, 0, 0, Math.PI * 2);
          ctx.fill();
          
          ctx.strokeStyle = '#000000';
          ctx.lineWidth = size * 0.04;
          ctx.beginPath();
          ctx.ellipse(-size * 0.1, 0, size * 0.15, size * 0.4, 0, 0, Math.PI * 2);
          ctx.stroke();
          ctx.beginPath();
          ctx.ellipse(size * 0.3, 0, size * 0.1, size * 0.35, 0, 0, Math.PI * 2);
          ctx.stroke();
        } else if (color.stripes === 'tang') {
          ctx.fillStyle = '#000000';
          ctx.beginPath();
          ctx.ellipse(-size * 0.1, 0, size * 0.25, size * 0.3, 0, 0, Math.PI * 2);
          ctx.fill();
          ctx.fillStyle = color.body || '#1e40af';
          ctx.beginPath();
          ctx.ellipse(-size * 0.1, 0, size * 0.18, size * 0.22, 0, 0, Math.PI * 2);
          ctx.fill();
        }

        // Eye
        ctx.fillStyle = '#ffffff';
        ctx.beginPath();
        ctx.arc(size * 0.55, -size * 0.1, size * 0.12, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = '#000000';
        ctx.beginPath();
        ctx.arc(size * 0.6, -size * 0.1, size * 0.06, 0, Math.PI * 2);
        ctx.fill();
        
        // Reflection
        ctx.fillStyle = '#ffffff';
        ctx.beginPath();
        ctx.arc(size * 0.58, -size * 0.12, size * 0.02, 0, Math.PI * 2);
        ctx.fill();

        ctx.restore();
      }

      // Bubble Particle System
      class Bubble {
        constructor() {
          this.reset();
          this.y = Math.random() * height; // distribute initial bubbles
        }
        reset() {
          this.x = Math.random() * width;
          this.y = height + 10;
          this.radius = 1 + Math.random() * 5;
          this.speed = 0.4 + Math.random() * 0.8;
          this.wiggleSpeed = 0.02 + Math.random() * 0.04;
          this.wiggleWidth = 1 + Math.random() * 2;
          this.angle = Math.random() * Math.PI * 2;
        }
        update() {
          this.y -= this.speed;
          this.angle += this.wiggleSpeed;
          this.xOffset = Math.sin(this.angle) * this.wiggleWidth;
          if (this.y < -10) this.reset();
        }
        draw() {
          ctx.save();
          ctx.beginPath();
          ctx.arc(this.x + this.xOffset, this.y, this.radius, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(255, 255, 255, 0.25)';
          ctx.fill();
          ctx.beginPath();
          ctx.arc(this.x + this.xOffset - this.radius * 0.3, this.y - this.radius * 0.3, this.radius * 0.2, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(255, 255, 255, 0.6)';
          ctx.fill();
          ctx.restore();
        }
      }

      // Fish Particle System
      class Fish {
        constructor() {
          this.reset(true);
        }
        reset(startRandom = false) {
          this.size = 18 + Math.random() * 20;
          this.depth = 0.4 + Math.random() * 0.6; // 3D depth multiplier
          this.size *= this.depth;
          
          const species = ['clownfish', 'bluetang', 'goldfish', 'tetra'];
          this.type = species[Math.floor(Math.random() * species.length)];
          if (this.type === 'clownfish') {
            this.color = { body: '#ff7e33', tail: '#ff3b3b', shading: '#882200', stripes: 'clownfish' };
          } else if (this.type === 'bluetang') {
            this.color = { body: '#2563eb', tail: '#facc15', shading: '#1e3a8a', stripes: 'tang' };
          } else if (this.type === 'goldfish') {
            this.color = { body: '#ffa500', tail: '#ef4444', shading: '#b45309' };
          } else {
            this.color = { body: '#06b6d4', tail: '#ec4899', shading: '#0891b2' };
          }

          this.isFacingLeft = Math.random() > 0.5;
          this.x = startRandom ? Math.random() * width : (this.isFacingLeft ? width + 60 : -60);
          this.y = 40 + Math.random() * (height - 80);
          this.speedX = (0.5 + Math.random() * 0.8) * this.depth * (this.isFacingLeft ? -1 : 1);
          this.speedY = (Math.random() - 0.5) * 0.15;
          this.tailWiggle = Math.random() * Math.PI * 2;
          this.tailWiggleSpeed = 0.08 + Math.random() * 0.08;
          this.angle = 0;
          
          this.isScared = false;
          this.scareTimer = 0;
        }
        scare(mouseX, mouseY) {
          const dx = this.x - mouseX;
          const dy = this.y - mouseY;
          const dist = Math.hypot(dx, dy);
          if (dist < 100) {
            this.isScared = true;
            this.scareTimer = 180;
            // Swim away fast
            this.speedX = (this.x > mouseX ? 3.0 : -3.0) * this.depth;
            this.speedY = (this.y > mouseY ? 1.5 : -1.5) * this.depth;
          }
        }
        update() {
          if (this.isScared) {
            this.x += this.speedX;
            this.y += this.speedY;
            this.tailWiggle += this.tailWiggleSpeed * 2.5;
            this.angle = this.speedY * 0.4;
            this.scareTimer--;
            if (this.scareTimer <= 0) {
              this.isScared = false;
              // Restore normal speed
              this.speedX = (0.5 + Math.random() * 0.8) * this.depth * (this.isFacingLeft ? -1 : 1);
              this.speedY = (Math.random() - 0.5) * 0.15;
            }
          } else {
            this.x += this.speedX;
            this.y += this.speedY;
            this.tailWiggle += this.tailWiggleSpeed;
            this.angle = this.speedY * 0.5;
          }

          if (this.isFacingLeft && this.x < -80) this.reset();
          if (!this.isFacingLeft && this.x > width + 80) this.reset();
          if (this.y < 30 || this.y > height - 30) this.speedY *= -1;
        }
        draw() {
          drawFish(ctx, this.x, this.y, this.size, this.angle, this.color, this.tailWiggle, this.isFacingLeft);
        }
      }

      // Seaweed Class
      class Seaweed {
        constructor(x, heightValue) {
          this.x = x;
          this.height = heightValue;
          this.angle = Math.random() * Math.PI * 2;
          this.speed = 0.015 + Math.random() * 0.015;
          this.width = 8 + Math.random() * 6;
        }
        update() {
          this.angle += this.speed;
        }
        draw() {
          ctx.save();
          ctx.strokeStyle = 'rgba(13, 148, 136, 0.25)';
          ctx.lineWidth = this.width;
          ctx.lineCap = 'round';
          ctx.beginPath();
          ctx.moveTo(this.x, height);
          
          const segments = 4;
          const segmentHeight = this.height / segments;
          let currentX = this.x;
          let currentY = height;
          
          for (let i = 0; i < segments; i++) {
            const targetY = height - (i + 1) * segmentHeight;
            const sway = Math.sin(this.angle + i * 0.5) * 12;
            const targetX = this.x + sway;
            const ctrlX = currentX + (targetX - currentX) / 2 + Math.sin(this.angle) * 3;
            const ctrlY = currentY - segmentHeight / 2;
            
            ctx.quadraticCurveTo(ctrlX, ctrlY, targetX, targetY);
            currentX = targetX;
            currentY = targetY;
          }
          ctx.stroke();
          ctx.restore();
        }
      }

      // Volumetric Light Shafts
      function drawLightShafts(time) {
        ctx.save();
        const numShafts = 5;
        for (let i = 0; i < numShafts; i++) {
          const shift = Math.sin(time * 0.001 + i * 1.5) * 60;
          const startX = (width / numShafts) * i + shift + 50;
          const shaftWidth = 50 + Math.sin(time * 0.002 + i) * 20;
          
          const grad = ctx.createLinearGradient(startX, 0, startX - 80, height);
          grad.addColorStop(0, 'rgba(56, 189, 248, 0.05)');
          grad.addColorStop(1, 'rgba(56, 189, 248, 0.0)');
          
          ctx.fillStyle = grad;
          ctx.beginPath();
          ctx.moveTo(startX - shaftWidth / 2, 0);
          ctx.lineTo(startX + shaftWidth / 2, 0);
          ctx.lineTo(startX + shaftWidth * 1.3 - 80, height);
          ctx.lineTo(startX - shaftWidth * 1.3 - 80, height);
          ctx.closePath();
          ctx.fill();
        }
        ctx.restore();
      }

      // Initialize Particles
      let bubbles = Array.from({ length: 45 }, () => new Bubble());
      let fishes = Array.from({ length: 8 }, () => new Fish());
      let seaweeds = Array.from({ length: 15 }, (_, i) => {
        const spacing = width / 16;
        return new Seaweed(spacing * (i + 0.5) + (Math.random() - 0.5) * 15, 60 + Math.random() * 80);
      });

      // Mouse Interaction
      canvas.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        const mouseX = e.clientX - rect.left;
        const mouseY = e.clientY - rect.top;
        
        // Scare fishes
        fishes.forEach(fish => fish.scare(mouseX, mouseY));
        
        // Spawn mini bubbles occasionally
        if (Math.random() < 0.25 && bubbles.length < 80) {
          const b = new Bubble();
          b.x = mouseX;
          b.y = mouseY;
          b.radius = 1 + Math.random() * 3;
          b.speed = 1.0 + Math.random() * 1.0;
          bubbles.push(b);
        }
      });

      canvas.addEventListener('click', (e) => {
        const rect = canvas.getBoundingClientRect();
        const mouseX = e.clientX - rect.left;
        const mouseY = e.clientY - rect.top;
        
        // Click scares fishes and spawns bubble explosion
        fishes.forEach(fish => {
          fish.scare(mouseX, mouseY);
          // speed up further
          if (fish.isScared) {
            fish.speedX *= 1.5;
            fish.speedY *= 1.5;
          }
        });
        
        for (let i = 0; i < 15; i++) {
          const b = new Bubble();
          b.x = mouseX + (Math.random() - 0.5) * 20;
          b.y = mouseY + (Math.random() - 0.5) * 20;
          b.radius = 1 + Math.random() * 4;
          b.speed = 0.8 + Math.random() * 1.5;
          bubbles.push(b);
        }
      });

      // Animation Loop
      function animate(time) {
        ctx.clearRect(0, 0, width, height);

        // 1. Draw water background gradient
        const bgGrad = ctx.createLinearGradient(0, 0, 0, height);
        bgGrad.addColorStop(0, '#090d16');
        bgGrad.addColorStop(0.5, '#0d182e');
        bgGrad.addColorStop(1, '#02050b');
        ctx.fillStyle = bgGrad;
        ctx.fillRect(0, 0, width, height);

        // 2. Draw light rays
        drawLightShafts(time);

        // 3. Draw Seaweed (background layer)
        seaweeds.forEach(s => {
          s.update();
          s.draw();
        });

        // 4. Update & Draw Fishes
        fishes.forEach(f => {
          f.update();
          f.draw();
        });

        // 5. Update & Draw Bubbles (foreground layer)
        bubbles.forEach((b, idx) => {
          b.update();
          b.draw();
          // Remove extra mini bubbles
          if (bubbles.length > 45 && b.y < -5) {
            bubbles.splice(idx, 1);
          }
        });

        requestAnimationFrame(animate);
      }
      
      requestAnimationFrame(animate);
    })();
  </script>
</BaseLayout>
