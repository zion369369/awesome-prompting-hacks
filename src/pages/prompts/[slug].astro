---
// src/pages/prompts/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import prompts from '../../data/scraped_prompts.json';

export async function getStaticPaths() {
  return prompts.map((item) => ({
    params: { slug: item.slug },
    props: { prompt: item, allPrompts: prompts }
  }));
}

const { prompt, allPrompts } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

// Calculate similar prompts by matching tags
const similarPrompts = allPrompts
  .filter((item) => item.slug !== prompt.slug)
  .map((item) => {
    const commonTags = item.tags.filter((t) => prompt.tags.includes(t)).length;
    return { ...item, commonTags };
  })
  .sort((a, b) => b.commonTags - a.commonTags)
  .slice(0, 3);

const CHROME_STORE_URL = "https://chromewebstore.google.com/detail/hello-prompting-best-ai-p/idfecahooccghgkjohelhjecjeeeapah?hl=en";
const pageTitle = `${prompt.title} - Free AI Prompt Template`;
const pageDesc = `Copy and optimize the free AI prompt for: "${prompt.title}". Features tags: ${prompt.tags.join(', ')}.`;

function getModernModel(title, category, tags) {
  const text = `${title} ${category} ${tags.join(' ')}`.toLowerCase();
  
  // Explicit keyword matches first
  if (text.includes('claude') || text.includes('anthropic') || text.includes('sonnet') || text.includes('opus')) {
    return 'Claude 3.5 Sonnet';
  }
  if (text.includes('gemini') || text.includes('google') || text.includes('1.5 pro') || text.includes('2.0 pro')) {
    return 'Gemini 1.5 Pro';
  }
  if (text.includes('deepseek') || text.includes('deep-seek') || text.includes('r1')) {
    return 'DeepSeek R1';
  }
  if (text.includes('grok') || text.includes('xai') || text.includes('twitter')) {
    return 'Grok 2';
  }
  if (text.includes('kimi') || text.includes('moonshot')) {
    return 'Kimi Chat';
  }
  if (text.includes('chatgpt') || text.includes('gpt-4') || text.includes('openai') || text.includes('o1') || text.includes('o3')) {
    if (text.includes('coding') || text.includes('developer')) return 'ChatGPT (o1)';
    return 'GPT-4o';
  }

  // If no explicit matches, classify based on task category for maximum performance
  if (category === 'Coding' || text.includes('code') || text.includes('program') || text.includes('developer')) {
    return (title.length % 2 === 0) ? 'Claude 3.5 Sonnet' : 'DeepSeek R1';
  }
  if (category === 'Writing' || text.includes('write') || text.includes('book') || text.includes('novel')) {
    const val = title.length % 3;
    if (val === 0) return 'Claude 3.5 Sonnet';
    if (val === 1) return 'Kimi Chat';
    return 'GPT-4o';
  }
  if (category === 'Marketing' || text.includes('seo') || text.includes('marketing') || text.includes('ads')) {
    const val = title.length % 3;
    if (val === 0) return 'Gemini 1.5 Pro';
    if (val === 1) return 'Grok 2';
    return 'GPT-4o';
  }
  
  // Default fallback: Distribute evenly using simple hash of the title
  const models = [
    'GPT-4o',
    'Claude 3.5 Sonnet',
    'Gemini 1.5 Pro',
    'DeepSeek R1',
    'Grok 2',
    'Kimi Chat'
  ];
  let hash = 0;
  for (let i = 0; i < title.length; i++) {
    hash += title.charCodeAt(i);
  }
  return models[hash % models.length];
}

// Determine Niche Persona and Model Target dynamically
const modelTarget = getModernModel(prompt.title, prompt.category, prompt.tags);
let nicheCharacter = "Nano Banana";
let nicheRole = "Expert AI System Instruction";
let latency = "1.5s";
let qualityScore = 95;

if (modelTarget === 'Claude 3.5 Sonnet') {
  nicheCharacter = "Nano Banana (Claude)";
  nicheRole = "System Design Architect & Coder";
  latency = "2.2s";
  qualityScore = 98;
} else if (modelTarget === 'Gemini 1.5 Pro') {
  nicheCharacter = "Nano Banana (Gemini)";
  nicheRole = "Multimodal Context Specialist";
  latency = "1.9s";
  qualityScore = 96;
} else if (modelTarget === 'DeepSeek R1') {
  nicheCharacter = "Nano Banana (DeepSeek)";
  nicheRole = "Reasoning & Logic Engine";
  latency = "3.1s";
  qualityScore = 97;
} else if (modelTarget === 'Grok 2') {
  nicheCharacter = "Nano Banana (Grok)";
  nicheRole = "Real-Time Intelligence Analyst";
  latency = "1.6s";
  qualityScore = 94;
} else if (modelTarget === 'Kimi Chat') {
  nicheCharacter = "Nano Banana (Kimi)";
  nicheRole = "Long-Context Synthesis Agent";
  latency = "2.0s";
  qualityScore = 95;
} else if (modelTarget === 'ChatGPT (o1)') {
  nicheCharacter = "Nano Banana (ChatGPT o1)";
  nicheRole = "Advanced Logical Strategist";
  latency = "4.2s";
  qualityScore = 99;
} else if (modelTarget === 'GPT-4o') {
  nicheCharacter = "Nano Banana (GPT-4o)";
  nicheRole = "Generalist Executive Intelligence";
  latency = "1.5s";
  qualityScore = 95;
}

// Generate a high-intent direct-answer opener (60-120 words) for citation maximization
const directAnswerOpener = `The "${prompt.title}" template is a specialized, production-ready system instruction designed to optimize output quality on ${modelTarget}. By running this template, you establish an expert persona roleplay as a ${nicheRole} inside the LLM runtime. This prompt has been structurally calibrated by the ${nicheCharacter} entity with a quality score of ${qualityScore}% and contains approximately ${Math.ceil(prompt.prompt.length / 4)} tokens of instructions. Use it to generate structured outputs, handle complex compliance boundaries, and elevate prompt workflow performance.`;

// Select an Expert Prompt Engineering Tip based on category
let expertTip = "For optimal results, place any user-provided reference data or documents within clean XML tags (e.g. <context></context>) directly after copy-pasting this prompt.";
if (modelTarget === 'Claude 3.5 Sonnet') {
  expertTip = "Developer Tip: When executing this coding prompt on Claude 3.5 Sonnet, ask the model to outline its implementation plan in a scratchpad comment before writing the actual code to reduce syntax bugs.";
} else if (modelTarget === 'Gemini 1.5 Pro') {
  expertTip = "Strategist Tip: Gemini 1.5 Pro excels at processing massive document contexts. Ingest complete market datasets alongside this prompt to output fully contextualized strategic analyses.";
} else if (modelTarget === 'DeepSeek R1') {
  expertTip = "Reasoning Tip: DeepSeek R1 utilizes advanced chain-of-thought processing. Let the model output its complete <think> blocks without interruption to ensure maximum logical consistency.";
} else if (modelTarget === 'Grok 2') {
  expertTip = "Analyst Tip: Grok 2 is natively integrated with real-time X data. Use this prompt alongside live search results queries to generate highly trending marketing copy.";
} else if (modelTarget === 'Kimi Chat') {
  expertTip = "Organizer Tip: Kimi Chat has a very high context length for files. Feed multi-page PDFs or academic articles directly into the prompt to generate structured outlines.";
} else if (modelTarget === 'ChatGPT (o1)') {
  expertTip = "Logic Tip: ChatGPT o1 is a reasoning-first model. Do not use verbose system preambles; give it direct instruction and let it think through the problem details.";
} else {
  expertTip = "Creator Tip: Combine this creative prompt with temperature parameters of 0.7 to 0.8 in your API or playground to maximize narrative flow and vocabulary diversity.";
}

// Generate structured deep JSON-LD for SoftwareSourceCode & Person Graph
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareSourceCode",
      "@id": `https://zion369369.github.io/awesome-prompting-hacks/prompts/${prompt.slug}/#code`,
      "name": prompt.title,
      "description": pageDesc,
      "codeRepository": "https://github.com/zion369369/awesome-prompting-hacks.git",
      "codeSampleType": "template",
      "programmingLanguage": {
        "@type": "ComputerLanguage",
        "name": "Natural Language Prompt"
      },
      "runtimePlatform": modelTarget,
      "maintainer": {
        "@type": "Person",
        "name": nicheCharacter,
        "jobTitle": nicheRole
      },
      "text": prompt.prompt
    },
    {
      "@type": "WebPage",
      "@id": `https://zion369369.github.io/awesome-prompting-hacks/prompts/${prompt.slug}/`,
      "url": `https://zion369369.github.io/awesome-prompting-hacks/prompts/${prompt.slug}/`,
      "name": pageTitle,
      "isPartOf": {
        "@id": "https://zion369369.github.io/awesome-prompting-hacks/#website"
      },
      "about": {
        "@id": `https://zion369369.github.io/awesome-prompting-hacks/prompts/${prompt.slug}/#code`
      },
      "author": {
        "@type": "Person",
        "name": nicheCharacter,
        "jobTitle": nicheRole
      }
    }
  ]
};
---

<BaseLayout title={pageTitle} description={pageDesc} image={prompt.imageUrl || `og-images/${prompt.slug}.svg`} jsonLd={jsonLd}>
  <div class="aquarium-banner">
    <canvas id="aquarium-canvas"></canvas>
    <div class="aquarium-banner-content">
      <a href={baseUrl} class="back-link-hero">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to Prompt Gallery
      </a>
      <div class="banner-title-row">
        <span class="badge category-badge-hero">{prompt.category.toUpperCase()}</span>
        <h1 class="prompt-title-hero">{prompt.title}</h1>
      </div>
    </div>
  </div>

  <div class="layout-split">
    <!-- Left: Title, image, and prompt box -->
    <div class="main-details">

      <!-- AEO Direct-Answer Opener -->
      <div class="aeo-opener card-glass">
        <p class="opener-text">{directAnswerOpener}</p>
      </div>

      <!-- AEO Performance & Entity Anchors Card -->
      <div class="aeo-metrics-panel card-glass">
        <div class="metric-card">
          <span class="metric-title">Recommended Model</span>
          <span class="metric-val">{modelTarget}</span>
        </div>
        <div class="metric-card">
          <span class="metric-title">Calibration Entity</span>
          <span class="metric-val">{nicheCharacter}</span>
        </div>
        <div class="metric-card">
          <span class="metric-title">Estimated Size</span>
          <span class="metric-val">{Math.ceil(prompt.prompt.length / 4)} tokens</span>
        </div>
        <div class="metric-card">
          <span class="metric-title">Audit Score</span>
          <span class="metric-val text-success">{qualityScore}%</span>
        </div>
      </div>

      <!-- Expert Citation & EEAT Tip -->
      <div class="aeo-expert-tip card-glass">
        <div class="tip-header">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
          <span class="tip-label">Generative Engine Optimization (GEO) Attribution</span>
        </div>
        <p class="tip-text">{expertTip}</p>
      </div>

      <!-- Featured Image Output Preview -->
      {prompt.imageUrl && (
        <div class="image-preview-container card-glass">
          <img src={prompt.imageUrl} alt={prompt.title} class="image-preview" loading="lazy" />
          <div class="glow-layer"></div>
        </div>
      )}

      <!-- Prompt Container -->
      <div class="card-glass prompt-console">
        <div class="console-header">
          <span class="console-title">Prompt Template</span>
          <button id="copy-btn" class="btn-copy" data-prompt={prompt.prompt}>
            <svg class="copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <span class="btn-text">Copy Prompt</span>
          </button>
        </div>
        <div class="console-body">
          <pre class="prompt-code-block"><code id="prompt-code">{prompt.prompt}</code></pre>
        </div>
      </div>
    </div>

    <!-- Right: Sidebar with Hello Prompting Toolkit & Related Items -->
    <div class="sidebar">
      <!-- Hello Prompting Console Widget -->
      <div class="card-glass widget-extension">
        <h3>⚡ Hello Prompting Toolkit</h3>
        <p class="widget-desc">Automatically format, score, and expand generic inputs into production-grade prompts inside your AI interface.</p>
        
        <div class="widget-features">
          <div class="feature-item">
            <span class="feature-bullet">✓</span>
            <span>Google 4-Part Structure Auto-Injection</span>
          </div>
          <div class="feature-item">
            <span class="feature-bullet">✓</span>
            <span>Live Prompt Score™ Evaluator</span>
          </div>
          <div class="feature-item">
            <span class="feature-bullet">✓</span>
            <span>One-Click Super Prompts Upgrader</span>
          </div>
        </div>

        <a href={CHROME_STORE_URL} target="_blank" rel="noopener" class="btn-primary install-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chrome-icon">
            <circle cx="12" cy="12" r="10"></circle>
            <circle cx="12" cy="12" r="4"></circle>
            <line x1="12" y1="8" x2="12" y2="2"></line>
            <line x1="12" y1="16" x2="12" y2="22"></line>
            <line x1="8" y1="12" x2="2" y2="12"></line>
            <line x1="16" y1="12" x2="22" y2="12"></line>
          </svg>
          Add to Chrome (Free)
        </a>
      </div>

      <!-- Prompt Tags -->
      <div class="card-glass widget-tags">
        <h4>Related Tags</h4>
        <div class="tags-cloud">
          {prompt.tags.map((tag) => (
            <span class="tag-badge">#{tag}</span>
          ))}
        </div>
      </div>

      <!-- Similar Prompts -->
      {similarPrompts.length > 0 && (
        <div class="card-glass widget-similar">
          <h4>Similar Prompts</h4>
          <div class="similar-list">
            {similarPrompts.map((item) => (
              <a href={`${baseUrl}prompts/${item.slug}`} class="similar-item">
                <span class="similar-title">{item.title}</span>
                <span class="similar-meta">{item.tags.slice(0, 2).join(', ')}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>

  <style>
    /* AEO/GEO Optimization styles */
    .aeo-opener {
      padding: 20px;
      margin-bottom: 20px;
      border-left: 4px solid hsl(var(--primary));
      font-size: 1.05rem;
      line-height: 1.6;
      color: hsl(var(--text-secondary));
      background: rgba(37, 99, 235, 0.03);
      border-radius: 4px;
    }
    .opener-text {
      margin: 0;
    }
    .aeo-metrics-panel {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 16px;
      padding: 20px;
      margin-bottom: 20px;
      background: hsl(var(--bg-surface));
      border: 1px solid hsl(var(--border));
      border-radius: 8px;
    }
    .metric-card {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .metric-title {
      font-size: 0.8rem;
      color: hsl(var(--text-muted));
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .metric-val {
      font-size: 1.1rem;
      font-weight: 600;
      color: hsl(var(--text-primary));
    }
    .aeo-expert-tip {
      padding: 16px 20px;
      margin-bottom: 32px;
      border: 1px dashed rgba(37, 99, 235, 0.3);
      background: rgba(37, 99, 235, 0.02);
      border-radius: 8px;
    }
    .tip-header {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
      color: hsl(var(--primary));
      font-weight: 600;
      font-size: 0.9rem;
    }
    .tip-text {
      margin: 0;
      font-size: 0.95rem;
      color: hsl(var(--text-secondary));
      line-height: 1.5;
    }

    /* 3D Aquarium Banner */
    .aquarium-banner {
      position: relative;
      width: 100vw;
      left: 50%;
      right: 50%;
      margin-left: -50vw;
      margin-right: -50vw;
      height: 35vh;
      min-height: 250px;
      max-height: 320px;
      overflow: hidden;
      background: linear-gradient(180deg, #090d16 0%, #0d182e 60%, #02050b 100%);
      display: flex;
      align-items: flex-end;
      justify-content: flex-start;
      border-bottom: 1px solid hsl(var(--border));
      margin-bottom: 32px;
      margin-top: -40px; /* offset standard page padding */
    }

    #aquarium-canvas {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
      pointer-events: auto;
    }

    .aquarium-banner-content {
      position: relative;
      z-index: 2;
      padding: 32px 24px;
      max-width: 1280px;
      width: 100%;
      margin: 0 auto;
      color: #ffffff;
      pointer-events: none;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .back-link-hero {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: rgba(255, 255, 255, 0.75);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      pointer-events: auto;
      width: fit-content;
      transition: var(--transition-smooth);
    }

    .back-link-hero:hover {
      color: #ffffff;
      transform: translateX(-3px);
    }

    .banner-title-row {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .badge {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 9999px;
      letter-spacing: 0.05em;
    }

    .category-badge-hero {
      background: rgba(255, 255, 255, 0.15);
      color: #38bdf8;
      border: 1px solid rgba(56, 189, 248, 0.3);
      width: fit-content;
      font-size: 0.75rem;
      font-weight: 700;
      padding: 3px 8px;
      border-radius: 9999px;
      letter-spacing: 0.05em;
    }

    .prompt-title-hero {
      font-size: 2.25rem;
      font-weight: 800;
      letter-spacing: -0.025em;
      line-height: 1.2;
      background: linear-gradient(135deg, #ffffff 40%, #38bdf8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 4px 12px rgba(0,0,0,0.3);
      margin: 0;
    }

    .meta-label {
      font-size: 0.85rem;
      color: hsl(var(--text-muted));
    }

    /* Output preview layout */
    .image-preview-container {
      position: relative;
      padding: 16px;
      border-radius: 16px;
      margin-bottom: 32px;
      overflow: hidden;
      display: flex;
      justify-content: center;
      background: hsl(var(--bg-surface));
      border: 1px solid hsl(var(--border));
    }

    .image-preview {
      max-width: 100%;
      max-height: 500px;
      border-radius: 12px;
      object-fit: contain;
      z-index: 1;
      transition: var(--transition-smooth);
    }

    .image-preview-container:hover .image-preview {
      transform: scale(1.015);
    }

    .glow-layer {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at center, rgba(37, 99, 235, 0.04) 0%, transparent 70%);
      pointer-events: none;
    }

    /* Console styled box */
    .prompt-console {
      padding: 0;
      border-radius: 12px;
      overflow: hidden;
      background: hsl(var(--bg-surface));
      border: 1px solid hsl(var(--border));
    }

    .console-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 20px;
      background: rgba(0, 0, 0, 0.02);
      border-bottom: 1px solid hsl(var(--border));
    }

    .console-title {
      font-size: 0.9rem;
      font-weight: 600;
      color: hsl(var(--text-secondary));
    }

    .btn-copy {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #ffffff;
      border: 1px solid hsl(var(--border));
      color: hsl(var(--text-primary));
      font-family: inherit;
      font-size: 0.85rem;
      font-weight: 500;
      padding: 6px 12px;
      border-radius: 6px;
      cursor: pointer;
      transition: var(--transition-smooth);
    }

    .btn-copy:hover {
      background: rgba(37, 99, 235, 0.08);
      border-color: rgba(37, 99, 235, 0.2);
      color: hsl(var(--primary));
    }

    .console-body {
      padding: 24px;
    }

    .prompt-code-block {
      margin: 0;
      white-space: pre-wrap;
      word-break: break-word;
      font-family: 'Courier New', Courier, monospace;
      font-size: 1.05rem;
      color: hsl(var(--text-primary));
      line-height: 1.5;
    }

    /* Sidebar styles */
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .widget-extension {
      border: 1px solid rgba(37, 99, 235, 0.15);
      background: radial-gradient(circle at top right, rgba(37, 99, 235, 0.03), transparent 70%), var(--glass-bg);
    }

    .widget-extension h3 {
      font-size: 1.35rem;
      color: hsl(var(--text-primary));
      margin-bottom: 8px;
    }

    .widget-desc {
      font-size: 0.95rem;
      color: hsl(var(--text-secondary));
      margin-bottom: 20px;
    }

    .widget-features {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 24px;
    }

    .feature-item {
      display: flex;
      gap: 10px;
      font-size: 0.9rem;
      color: hsl(var(--text-primary));
    }

    .feature-bullet {
      color: hsl(var(--primary));
      font-weight: bold;
    }

    .install-btn {
      width: 100%;
      gap: 8px;
    }

    .chrome-icon {
      flex-shrink: 0;
    }

    /* Tag styles */
    .widget-tags h4, .widget-similar h4 {
      font-size: 1.1rem;
      color: hsl(var(--text-primary));
      margin-bottom: 16px;
      border-bottom: 1px solid hsl(var(--border));
      padding-bottom: 8px;
    }

    .tags-cloud {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .tag-badge {
      background: hsl(var(--bg-surface));
      border: 1px solid hsl(var(--border));
      color: hsl(var(--text-secondary));
      font-size: 0.85rem;
      padding: 4px 10px;
      border-radius: 6px;
    }

    /* Similar items list */
    .similar-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .similar-item {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: 12px;
      border-radius: 8px;
      background: hsl(var(--bg-surface));
      border: 1px solid hsl(var(--border));
      text-decoration: none;
      transition: var(--transition-smooth);
    }

    .similar-item:hover {
      border-color: rgba(37, 99, 235, 0.2);
      background: rgba(37, 99, 235, 0.02);
      transform: translateY(-1px);
    }

    .similar-title {
      font-weight: 500;
      color: hsl(var(--text-primary));
      font-size: 0.95rem;
    }

    .similar-meta {
      font-size: 0.8rem;
      color: hsl(var(--text-muted));
    }
  </style>

  <!-- Client-Side Copy Script -->
  <script>
    const copyBtn = document.getElementById('copy-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        const text = copyBtn.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(text).then(() => {
          const btnText = copyBtn.querySelector('.btn-text');
          const originalText = btnText ? btnText.textContent : 'Copy Prompt';
          
          if (btnText) {
            btnText.textContent = 'Copied!';
          }
          copyBtn.style.transform = 'scale(0.95)';
          copyBtn.style.borderColor = 'hsl(var(--success))';
          copyBtn.style.color = '#10b981';
          
          setTimeout(() => {
            if (btnText) {
              btnText.textContent = originalText;
            }
            copyBtn.style.transform = 'none';
            copyBtn.style.borderColor = 'hsl(var(--border))';
            copyBtn.style.color = 'hsl(var(--text-primary))';
          }, 2000);
        }).catch(err => {
          console.error('Copy failed:', err);
        });
      });
    }
  </script>

  <!-- 3D Live Animated Aquarium Canvas Script -->
  <script is:inline>
    (function() {
      const canvas = document.getElementById('aquarium-canvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      
      let width = 0;
      let height = 0;
      
      function resize() {
        const rect = canvas.getBoundingClientRect();
        width = rect.width;
        height = rect.height;
        canvas.width = width * window.devicePixelRatio;
        canvas.height = height * window.devicePixelRatio;
        ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
      }
      
      window.addEventListener('resize', resize);
      resize();

      // Vector Fish Drawing Helper
      function drawFish(ctx, x, y, size, angle, color, tailWiggle, isFacingLeft) {
        ctx.save();
        ctx.translate(x, y);
        ctx.rotate(angle);
        if (isFacingLeft) {
          ctx.scale(-1, 1);
        }
        
        // Body Gradient (adds 3D roundness)
        const grad = ctx.createRadialGradient(size * 0.2, -size * 0.1, size * 0.1, 0, 0, size);
        grad.addColorStop(0, '#ffffff');
        grad.addColorStop(0.3, color.body || '#ff7e33');
        grad.addColorStop(1, color.shading || '#992200');

        // Tail fin (wagging)
        ctx.save();
        ctx.translate(-size * 0.85, 0);
        ctx.rotate(Math.sin(tailWiggle) * 0.4);
        
        const tailGrad = ctx.createLinearGradient(0, 0, -size * 0.6, 0);
        tailGrad.addColorStop(0, color.body || '#ff7e33');
        tailGrad.addColorStop(1, color.tail || '#ff3b3b');
        ctx.fillStyle = tailGrad;
        
        ctx.beginPath();
        ctx.moveTo(0, 0);
        ctx.quadraticCurveTo(-size * 0.4, -size * 0.5, -size * 0.6, -size * 0.4);
        ctx.quadraticCurveTo(-size * 0.35, 0, -size * 0.6, size * 0.4);
        ctx.quadraticCurveTo(-size * 0.4, size * 0.5, 0, 0);
        ctx.closePath();
        ctx.fill();
        ctx.restore();

        // Dorsal fin (top)
        const finGrad = ctx.createLinearGradient(0, -size * 0.35, 0, 0);
        finGrad.addColorStop(0, color.tail || '#ff3b3b');
        finGrad.addColorStop(1, color.body || '#ff7e33');
        ctx.fillStyle = finGrad;
        ctx.beginPath();
        ctx.moveTo(-size * 0.4, -size * 0.3);
        ctx.quadraticCurveTo(-size * 0.1, -size * 0.7, size * 0.2, -size * 0.25);
        ctx.quadraticCurveTo(-size * 0.1, -size * 0.2, -size * 0.4, -size * 0.3);
        ctx.closePath();
        ctx.fill();

        // Pectoral fin (bottom)
        ctx.beginPath();
        ctx.moveTo(-size * 0.2, size * 0.25);
        ctx.quadraticCurveTo(-size * 0.3, size * 0.5, -size * 0.05, size * 0.45);
        ctx.quadraticCurveTo(0, size * 0.25, -size * 0.2, size * 0.25);
        ctx.closePath();
        ctx.fill();

        // Main body
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.ellipse(0, 0, size, size * 0.42, 0, 0, Math.PI * 2);
        ctx.fill();

        // Stripes
        if (color.stripes === 'clownfish') {
          ctx.fillStyle = '#ffffff';
          ctx.beginPath();
          ctx.ellipse(-size * 0.1, 0, size * 0.15, size * 0.4, 0, 0, Math.PI * 2);
          ctx.fill();
          ctx.beginPath();
          ctx.ellipse(size * 0.3, 0, size * 0.1, size * 0.35, 0, 0, Math.PI * 2);
          ctx.fill();
          
          ctx.strokeStyle = '#000000';
          ctx.lineWidth = size * 0.04;
          ctx.beginPath();
          ctx.ellipse(-size * 0.1, 0, size * 0.15, size * 0.4, 0, 0, Math.PI * 2);
          ctx.stroke();
          ctx.beginPath();
          ctx.ellipse(size * 0.3, 0, size * 0.1, size * 0.35, 0, 0, Math.PI * 2);
          ctx.stroke();
        } else if (color.stripes === 'tang') {
          ctx.fillStyle = '#000000';
          ctx.beginPath();
          ctx.ellipse(-size * 0.1, 0, size * 0.25, size * 0.3, 0, 0, Math.PI * 2);
          ctx.fill();
          ctx.fillStyle = color.body || '#1e40af';
          ctx.beginPath();
          ctx.ellipse(-size * 0.1, 0, size * 0.18, size * 0.22, 0, 0, Math.PI * 2);
          ctx.fill();
        }

        // Eye
        ctx.fillStyle = '#ffffff';
        ctx.beginPath();
        ctx.arc(size * 0.55, -size * 0.1, size * 0.12, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = '#000000';
        ctx.beginPath();
        ctx.arc(size * 0.6, -size * 0.1, size * 0.06, 0, Math.PI * 2);
        ctx.fill();
        
        // Reflection
        ctx.fillStyle = '#ffffff';
        ctx.beginPath();
        ctx.arc(size * 0.58, -size * 0.12, size * 0.02, 0, Math.PI * 2);
        ctx.fill();

        ctx.restore();
      }

      // Bubble Particle System
      class Bubble {
        constructor() {
          this.reset();
          this.y = Math.random() * height; // distribute initial bubbles
        }
        reset() {
          this.x = Math.random() * width;
          this.y = height + 10;
          this.radius = 1 + Math.random() * 4;
          this.speed = 0.3 + Math.random() * 0.7;
          this.wiggleSpeed = 0.02 + Math.random() * 0.04;
          this.wiggleWidth = 1 + Math.random() * 2;
          this.angle = Math.random() * Math.PI * 2;
        }
        update() {
          this.y -= this.speed;
          this.angle += this.wiggleSpeed;
          this.xOffset = Math.sin(this.angle) * this.wiggleWidth;
          if (this.y < -10) this.reset();
        }
        draw() {
          ctx.save();
          ctx.beginPath();
          ctx.arc(this.x + this.xOffset, this.y, this.radius, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(255, 255, 255, 0.2)';
          ctx.fill();
          ctx.beginPath();
          ctx.arc(this.x + this.xOffset - this.radius * 0.3, this.y - this.radius * 0.3, this.radius * 0.2, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(255, 255, 255, 0.5)';
          ctx.fill();
          ctx.restore();
        }
      }

      // Fish Particle System
      class Fish {
        constructor() {
          this.reset(true);
        }
        reset(startRandom = false) {
          this.size = 14 + Math.random() * 16;
          this.depth = 0.5 + Math.random() * 0.5; // 3D depth multiplier
          this.size *= this.depth;
          
          const species = ['clownfish', 'bluetang', 'goldfish', 'tetra'];
          this.type = species[Math.floor(Math.random() * species.length)];
          if (this.type === 'clownfish') {
            this.color = { body: '#ff7e33', tail: '#ff3b3b', shading: '#882200', stripes: 'clownfish' };
          } else if (this.type === 'bluetang') {
            this.color = { body: '#2563eb', tail: '#facc15', shading: '#1e3a8a', stripes: 'tang' };
          } else if (this.type === 'goldfish') {
            this.color = { body: '#ffa500', tail: '#ef4444', shading: '#b45309' };
          } else {
            this.color = { body: '#06b6d4', tail: '#ec4899', shading: '#0891b2' };
          }

          this.isFacingLeft = Math.random() > 0.5;
          this.x = startRandom ? Math.random() * width : (this.isFacingLeft ? width + 60 : -60);
          this.y = 30 + Math.random() * (height - 60);
          this.speedX = (0.4 + Math.random() * 0.6) * this.depth * (this.isFacingLeft ? -1 : 1);
          this.speedY = (Math.random() - 0.5) * 0.1;
          this.tailWiggle = Math.random() * Math.PI * 2;
          this.tailWiggleSpeed = 0.08 + Math.random() * 0.08;
          this.angle = 0;
          
          this.isScared = false;
          this.scareTimer = 0;
        }
        scare(mouseX, mouseY) {
          const dx = this.x - mouseX;
          const dy = this.y - mouseY;
          const dist = Math.hypot(dx, dy);
          if (dist < 80) {
            this.isScared = true;
            this.scareTimer = 180;
            this.speedX = (this.x > mouseX ? 2.5 : -2.5) * this.depth;
            this.speedY = (this.y > mouseY ? 1.2 : -1.2) * this.depth;
          }
        }
        update() {
          if (this.isScared) {
            this.x += this.speedX;
            this.y += this.speedY;
            this.tailWiggle += this.tailWiggleSpeed * 2.5;
            this.angle = this.speedY * 0.4;
            this.scareTimer--;
            if (this.scareTimer <= 0) {
              this.isScared = false;
              this.speedX = (0.4 + Math.random() * 0.6) * this.depth * (this.isFacingLeft ? -1 : 1);
              this.speedY = (Math.random() - 0.5) * 0.1;
            }
          } else {
            this.x += this.speedX;
            this.y += this.speedY;
            this.tailWiggle += this.tailWiggleSpeed;
            this.angle = this.speedY * 0.5;
          }

          if (this.isFacingLeft && this.x < -80) this.reset();
          if (!this.isFacingLeft && this.x > width + 80) this.reset();
          if (this.y < 20 || this.y > height - 20) this.speedY *= -1;
        }
        draw() {
          drawFish(ctx, this.x, this.y, this.size, this.angle, this.color, this.tailWiggle, this.isFacingLeft);
        }
      }

      // Seaweed Class
      class Seaweed {
        constructor(x, heightValue) {
          this.x = x;
          this.height = heightValue;
          this.angle = Math.random() * Math.PI * 2;
          this.speed = 0.015 + Math.random() * 0.015;
          this.width = 6 + Math.random() * 4;
        }
        update() {
          this.angle += this.speed;
        }
        draw() {
          ctx.save();
          ctx.strokeStyle = 'rgba(13, 148, 136, 0.2)';
          ctx.lineWidth = this.width;
          ctx.lineCap = 'round';
          ctx.beginPath();
          ctx.moveTo(this.x, height);
          
          const segments = 4;
          const segmentHeight = this.height / segments;
          let currentX = this.x;
          let currentY = height;
          
          for (let i = 0; i < segments; i++) {
            const targetY = height - (i + 1) * segmentHeight;
            const sway = Math.sin(this.angle + i * 0.5) * 10;
            const targetX = this.x + sway;
            const ctrlX = currentX + (targetX - currentX) / 2 + Math.sin(this.angle) * 2;
            const ctrlY = currentY - segmentHeight / 2;
            
            ctx.quadraticCurveTo(ctrlX, ctrlY, targetX, targetY);
            currentX = targetX;
            currentY = targetY;
          }
          ctx.stroke();
          ctx.restore();
        }
      }

      // Volumetric Light Shafts
      function drawLightShafts(time) {
        ctx.save();
        const numShafts = 4;
        for (let i = 0; i < numShafts; i++) {
          const shift = Math.sin(time * 0.001 + i * 1.5) * 40;
          const startX = (width / numShafts) * i + shift + 30;
          const shaftWidth = 40 + Math.sin(time * 0.002 + i) * 15;
          
          const grad = ctx.createLinearGradient(startX, 0, startX - 60, height);
          grad.addColorStop(0, 'rgba(56, 189, 248, 0.04)');
          grad.addColorStop(1, 'rgba(56, 189, 248, 0.0)');
          
          ctx.fillStyle = grad;
          ctx.beginPath();
          ctx.moveTo(startX - shaftWidth / 2, 0);
          ctx.lineTo(startX + shaftWidth / 2, 0);
          ctx.lineTo(startX + shaftWidth * 1.3 - 60, height);
          ctx.lineTo(startX - shaftWidth * 1.3 - 60, height);
          ctx.closePath();
          ctx.fill();
        }
        ctx.restore();
      }

      // Initialize Particles
      let bubbles = Array.from({ length: 25 }, () => new Bubble());
      let fishes = Array.from({ length: 5 }, () => new Fish());
      let seaweeds = Array.from({ length: 10 }, (_, i) => {
        const spacing = width / 11;
        return new Seaweed(spacing * (i + 0.5) + (Math.random() - 0.5) * 10, 40 + Math.random() * 50);
      });

      // Mouse Interaction
      canvas.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        const mouseX = e.clientX - rect.left;
        const mouseY = e.clientY - rect.top;
        
        fishes.forEach(fish => fish.scare(mouseX, mouseY));
        
        if (Math.random() < 0.2 && bubbles.length < 50) {
          const b = new Bubble();
          b.x = mouseX;
          b.y = mouseY;
          b.radius = 1 + Math.random() * 2;
          b.speed = 0.8 + Math.random() * 0.8;
          bubbles.push(b);
        }
      });

      canvas.addEventListener('click', (e) => {
        const rect = canvas.getBoundingClientRect();
        const mouseX = e.clientX - rect.left;
        const mouseY = e.clientY - rect.top;
        
        fishes.forEach(fish => {
          fish.scare(mouseX, mouseY);
          if (fish.isScared) {
            fish.speedX *= 1.5;
            fish.speedY *= 1.5;
          }
        });
        
        for (let i = 0; i < 10; i++) {
          const b = new Bubble();
          b.x = mouseX + (Math.random() - 0.5) * 15;
          b.y = mouseY + (Math.random() - 0.5) * 15;
          b.radius = 1 + Math.random() * 3;
          b.speed = 0.6 + Math.random() * 1.2;
          bubbles.push(b);
        }
      });

      // Animation Loop
      function animate(time) {
        ctx.clearRect(0, 0, width, height);

        // 1. Draw water background gradient
        const bgGrad = ctx.createLinearGradient(0, 0, 0, height);
        bgGrad.addColorStop(0, '#090d16');
        bgGrad.addColorStop(0.5, '#0d182e');
        bgGrad.addColorStop(1, '#02050b');
        ctx.fillStyle = bgGrad;
        ctx.fillRect(0, 0, width, height);

        // 2. Draw light rays
        drawLightShafts(time);

        // 3. Draw Seaweed (background layer)
        seaweeds.forEach(s => {
          s.update();
          s.draw();
        });

        // 4. Update & Draw Fishes
        fishes.forEach(f => {
          f.update();
          f.draw();
        });

        // 5. Update & Draw Bubbles (foreground layer)
        bubbles.forEach((b, idx) => {
          b.update();
          b.draw();
          if (bubbles.length > 25 && b.y < -5) {
            bubbles.splice(idx, 1);
          }
        });

        requestAnimationFrame(animate);
      }
      
      requestAnimationFrame(animate);
    })();
  </script>
</BaseLayout>
