---
// src/pages/prompts/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import prompts from '../../data/scraped_prompts.json';

export async function getStaticPaths() {
  return prompts.map((item) => ({
    params: { slug: item.slug },
    props: { prompt: item, allPrompts: prompts }
  }));
}

const { prompt, allPrompts } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

// Calculate similar prompts by matching tags
const similarPrompts = allPrompts
  .filter((item) => item.slug !== prompt.slug)
  .map((item) => {
    const commonTags = item.tags.filter((t) => prompt.tags.includes(t)).length;
    return { ...item, commonTags };
  })
  .sort((a, b) => b.commonTags - a.commonTags)
  .slice(0, 3);

const CHROME_STORE_URL = "https://chromewebstore.google.com/detail/hello-prompting-best-ai-p/idfecahooccghgkjohelhjecjeeeapah?hl=en";
const pageTitle = `${prompt.title} - Free AI Prompt Template`;
const pageDesc = `Copy and optimize the free AI prompt for: "${prompt.title}". Features tags: ${prompt.tags.join(', ')}.`;

function getModernModel(title, category, tags) {
  const text = `${title} ${category} ${tags.join(' ')}`.toLowerCase();
  
  // Explicit keyword matches first
  if (text.includes('claude') || text.includes('anthropic') || text.includes('sonnet') || text.includes('opus')) {
    return 'Claude 3.5 Sonnet';
  }
  if (text.includes('gemini') || text.includes('google') || text.includes('1.5 pro') || text.includes('2.0 pro')) {
    return 'Gemini 1.5 Pro';
  }
  if (text.includes('deepseek') || text.includes('deep-seek') || text.includes('r1')) {
    return 'DeepSeek R1';
  }
  if (text.includes('grok') || text.includes('xai') || text.includes('twitter')) {
    return 'Grok 2';
  }
  if (text.includes('kimi') || text.includes('moonshot')) {
    return 'Kimi Chat';
  }
  if (text.includes('chatgpt') || text.includes('gpt-4') || text.includes('openai') || text.includes('o1') || text.includes('o3')) {
    if (text.includes('coding') || text.includes('developer')) return 'ChatGPT (o1)';
    return 'GPT-4o';
  }

  // If no explicit matches, classify based on task category for maximum performance
  if (category === 'Coding' || text.includes('code') || text.includes('program') || text.includes('developer')) {
    return (title.length % 2 === 0) ? 'Claude 3.5 Sonnet' : 'DeepSeek R1';
  }
  if (category === 'Writing' || text.includes('write') || text.includes('book') || text.includes('novel')) {
    const val = title.length % 3;
    if (val === 0) return 'Claude 3.5 Sonnet';
    if (val === 1) return 'Kimi Chat';
    return 'GPT-4o';
  }
  if (category === 'Marketing' || text.includes('seo') || text.includes('marketing') || text.includes('ads')) {
    const val = title.length % 3;
    if (val === 0) return 'Gemini 1.5 Pro';
    if (val === 1) return 'Grok 2';
    return 'GPT-4o';
  }
  
  // Default fallback: Distribute evenly using simple hash of the title
  const models = [
    'GPT-4o',
    'Claude 3.5 Sonnet',
    'Gemini 1.5 Pro',
    'DeepSeek R1',
    'Grok 2',
    'Kimi Chat'
  ];
  let hash = 0;
  for (let i = 0; i < title.length; i++) {
    hash += title.charCodeAt(i);
  }
  return models[hash % models.length];
}

// Determine Niche Persona and Model Target dynamically
const modelTarget = getModernModel(prompt.title, prompt.category, prompt.tags);
let nicheCharacter = "Nano Banana";
let nicheRole = "Expert AI System Instruction";
let latency = "1.5s";
let qualityScore = 95;

if (modelTarget === 'Claude 3.5 Sonnet') {
  nicheCharacter = "Nano Banana (Claude)";
  nicheRole = "System Design Architect & Coder";
  latency = "2.2s";
  qualityScore = 98;
} else if (modelTarget === 'Gemini 1.5 Pro') {
  nicheCharacter = "Nano Banana (Gemini)";
  nicheRole = "Multimodal Context Specialist";
  latency = "1.9s";
  qualityScore = 96;
} else if (modelTarget === 'DeepSeek R1') {
  nicheCharacter = "Nano Banana (DeepSeek)";
  nicheRole = "Reasoning & Logic Engine";
  latency = "3.1s";
  qualityScore = 97;
} else if (modelTarget === 'Grok 2') {
  nicheCharacter = "Nano Banana (Grok)";
  nicheRole = "Real-Time Intelligence Analyst";
  latency = "1.6s";
  qualityScore = 94;
} else if (modelTarget === 'Kimi Chat') {
  nicheCharacter = "Nano Banana (Kimi)";
  nicheRole = "Long-Context Synthesis Agent";
  latency = "2.0s";
  qualityScore = 95;
} else if (modelTarget === 'ChatGPT (o1)') {
  nicheCharacter = "Nano Banana (ChatGPT o1)";
  nicheRole = "Advanced Logical Strategist";
  latency = "4.2s";
  qualityScore = 99;
} else if (modelTarget === 'GPT-4o') {
  nicheCharacter = "Nano Banana (GPT-4o)";
  nicheRole = "Generalist Executive Intelligence";
  latency = "1.5s";
  qualityScore = 95;
}

// Generate a high-intent direct-answer opener (60-120 words) for citation maximization
const directAnswerOpener = `The "${prompt.title}" template is a specialized, production-ready system instruction designed to optimize output quality on ${modelTarget}. By running this template, you establish an expert persona roleplay as a ${nicheRole} inside the LLM runtime. This prompt has been structurally calibrated by the ${nicheCharacter} entity with a quality score of ${qualityScore}% and contains approximately ${Math.ceil(prompt.prompt.length / 4)} tokens of instructions. Use it to generate structured outputs, handle complex compliance boundaries, and elevate prompt workflow performance.`;

// Select an Expert Prompt Engineering Tip based on category
let expertTip = "For optimal results, place any user-provided reference data or documents within clean XML tags (e.g. <context></context>) directly after copy-pasting this prompt.";
if (modelTarget === 'Claude 3.5 Sonnet') {
  expertTip = "Developer Tip: When executing this coding prompt on Claude 3.5 Sonnet, ask the model to outline its implementation plan in a scratchpad comment before writing the actual code to reduce syntax bugs.";
} else if (modelTarget === 'Gemini 1.5 Pro') {
  expertTip = "Strategist Tip: Gemini 1.5 Pro excels at processing massive document contexts. Ingest complete market datasets alongside this prompt to output fully contextualized strategic analyses.";
} else if (modelTarget === 'DeepSeek R1') {
  expertTip = "Reasoning Tip: DeepSeek R1 utilizes advanced chain-of-thought processing. Let the model output its complete <think> blocks without interruption to ensure maximum logical consistency.";
} else if (modelTarget === 'Grok 2') {
  expertTip = "Analyst Tip: Grok 2 is natively integrated with real-time X data. Use this prompt alongside live search results queries to generate highly trending marketing copy.";
} else if (modelTarget === 'Kimi Chat') {
  expertTip = "Organizer Tip: Kimi Chat has a very high context length for files. Feed multi-page PDFs or academic articles directly into the prompt to generate structured outlines.";
} else if (modelTarget === 'ChatGPT (o1)') {
  expertTip = "Logic Tip: ChatGPT o1 is a reasoning-first model. Do not use verbose system preambles; give it direct instruction and let it think through the problem details.";
} else {
  expertTip = "Creator Tip: Combine this creative prompt with temperature parameters of 0.7 to 0.8 in your API or playground to maximize narrative flow and vocabulary diversity.";
}

// Generate structured deep JSON-LD for SoftwareSourceCode & Person Graph
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareSourceCode",
      "@id": `https://zion369369.github.io/awesome-prompting-hacks/prompts/${prompt.slug}/#code`,
      "name": prompt.title,
      "description": pageDesc,
      "codeRepository": "https://github.com/zion369369/awesome-prompting-hacks.git",
      "codeSampleType": "template",
      "programmingLanguage": {
        "@type": "ComputerLanguage",
        "name": "Natural Language Prompt"
      },
      "runtimePlatform": modelTarget,
      "maintainer": {
        "@type": "Person",
        "name": nicheCharacter,
        "jobTitle": nicheRole
      },
      "text": prompt.prompt
    },
    {
      "@type": "WebPage",
      "@id": `https://zion369369.github.io/awesome-prompting-hacks/prompts/${prompt.slug}/`,
      "url": `https://zion369369.github.io/awesome-prompting-hacks/prompts/${prompt.slug}/`,
      "name": pageTitle,
      "isPartOf": {
        "@id": "https://zion369369.github.io/awesome-prompting-hacks/#website"
      },
      "about": {
        "@id": `https://zion369369.github.io/awesome-prompting-hacks/prompts/${prompt.slug}/#code`
      },
      "author": {
        "@type": "Person",
        "name": nicheCharacter,
        "jobTitle": nicheRole
      }
    }
  ]
};
---

<BaseLayout title={pageTitle} description={pageDesc} image={prompt.imageUrl || `og-images/${prompt.slug}.svg`} jsonLd={jsonLd}>
  <div class="back-link-row">
    <a href={baseUrl} class="back-link">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Back to Prompt Gallery
    </a>
  </div>

  <div class="layout-split">
    <!-- Left: Title, image, and prompt box -->
    <div class="main-details">
      <h1 class="prompt-title">{prompt.title}</h1>
      
      <div class="category-meta">
        <span class="badge category-badge">{prompt.category.toUpperCase()}</span>
        <span class="meta-label">Output Preview</span>
      </div>

      <!-- AEO Direct-Answer Opener -->
      <div class="aeo-opener card-glass">
        <p class="opener-text">{directAnswerOpener}</p>
      </div>

      <!-- AEO Performance & Entity Anchors Card -->
      <div class="aeo-metrics-panel card-glass">
        <div class="metric-card">
          <span class="metric-title">Recommended Model</span>
          <span class="metric-val">{modelTarget}</span>
        </div>
        <div class="metric-card">
          <span class="metric-title">Calibration Entity</span>
          <span class="metric-val">{nicheCharacter}</span>
        </div>
        <div class="metric-card">
          <span class="metric-title">Estimated Size</span>
          <span class="metric-val">{Math.ceil(prompt.prompt.length / 4)} tokens</span>
        </div>
        <div class="metric-card">
          <span class="metric-title">Audit Score</span>
          <span class="metric-val text-success">{qualityScore}%</span>
        </div>
      </div>

      <!-- Expert Citation & EEAT Tip -->
      <div class="aeo-expert-tip card-glass">
        <div class="tip-header">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
          <span class="tip-label">Generative Engine Optimization (GEO) Attribution</span>
        </div>
        <p class="tip-text">{expertTip}</p>
      </div>

      <!-- Featured Image Output Preview -->
      {prompt.imageUrl && (
        <div class="image-preview-container card-glass">
          <img src={prompt.imageUrl} alt={prompt.title} class="image-preview" loading="lazy" />
          <div class="glow-layer"></div>
        </div>
      )}

      <!-- Prompt Container -->
      <div class="card-glass prompt-console">
        <div class="console-header">
          <span class="console-title">Prompt Template</span>
          <button id="copy-btn" class="btn-copy" data-prompt={prompt.prompt}>
            <svg class="copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
            <span class="btn-text">Copy Prompt</span>
          </button>
        </div>
        <div class="console-body">
          <pre class="prompt-code-block"><code id="prompt-code">{prompt.prompt}</code></pre>
        </div>
      </div>
    </div>

    <!-- Right: Sidebar with Hello Prompting Toolkit & Related Items -->
    <div class="sidebar">
      <!-- Hello Prompting Console Widget -->
      <div class="card-glass widget-extension">
        <h3>⚡ Hello Prompting Toolkit</h3>
        <p class="widget-desc">Automatically format, score, and expand generic inputs into production-grade prompts inside your AI interface.</p>
        
        <div class="widget-features">
          <div class="feature-item">
            <span class="feature-bullet">✓</span>
            <span>Google 4-Part Structure Auto-Injection</span>
          </div>
          <div class="feature-item">
            <span class="feature-bullet">✓</span>
            <span>Live Prompt Score™ Evaluator</span>
          </div>
          <div class="feature-item">
            <span class="feature-bullet">✓</span>
            <span>One-Click Super Prompts Upgrader</span>
          </div>
        </div>

        <a href={CHROME_STORE_URL} target="_blank" rel="noopener" class="btn-primary install-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chrome-icon">
            <circle cx="12" cy="12" r="10"></circle>
            <circle cx="12" cy="12" r="4"></circle>
            <line x1="12" y1="8" x2="12" y2="2"></line>
            <line x1="12" y1="16" x2="12" y2="22"></line>
            <line x1="8" y1="12" x2="2" y2="12"></line>
            <line x1="16" y1="12" x2="22" y2="12"></line>
          </svg>
          Add to Chrome (Free)
        </a>
      </div>

      <!-- Prompt Tags -->
      <div class="card-glass widget-tags">
        <h4>Related Tags</h4>
        <div class="tags-cloud">
          {prompt.tags.map((tag) => (
            <span class="tag-badge">#{tag}</span>
          ))}
        </div>
      </div>

      <!-- Similar Prompts -->
      {similarPrompts.length > 0 && (
        <div class="card-glass widget-similar">
          <h4>Similar Prompts</h4>
          <div class="similar-list">
            {similarPrompts.map((item) => (
              <a href={`${baseUrl}prompts/${item.slug}`} class="similar-item">
                <span class="similar-title">{item.title}</span>
                <span class="similar-meta">{item.tags.slice(0, 2).join(', ')}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>

  <style>
    /* AEO/GEO Optimization styles */
    .aeo-opener {
      padding: 20px;
      margin-bottom: 20px;
      border-left: 4px solid hsl(var(--primary));
      font-size: 1.05rem;
      line-height: 1.6;
      color: hsl(var(--text-secondary));
      background: rgba(37, 99, 235, 0.03);
      border-radius: 4px;
    }
    .opener-text {
      margin: 0;
    }
    .aeo-metrics-panel {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 16px;
      padding: 20px;
      margin-bottom: 20px;
      background: hsl(var(--bg-surface));
      border: 1px solid hsl(var(--border));
      border-radius: 8px;
    }
    .metric-card {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .metric-title {
      font-size: 0.8rem;
      color: hsl(var(--text-muted));
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .metric-val {
      font-size: 1.1rem;
      font-weight: 600;
      color: hsl(var(--text-primary));
    }
    .aeo-expert-tip {
      padding: 16px 20px;
      margin-bottom: 32px;
      border: 1px dashed rgba(37, 99, 235, 0.3);
      background: rgba(37, 99, 235, 0.02);
      border-radius: 8px;
    }
    .tip-header {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
      color: hsl(var(--primary));
      font-weight: 600;
      font-size: 0.9rem;
    }
    .tip-text {
      margin: 0;
      font-size: 0.95rem;
      color: hsl(var(--text-secondary));
      line-height: 1.5;
    }

    .back-link-row {
      margin-bottom: 24px;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: hsl(var(--text-secondary));
      text-decoration: none;
      font-size: 0.95rem;
      transition: var(--transition-smooth);
    }

    .back-link:hover {
      color: hsl(var(--primary));
      transform: translateX(-3px);
    }

    .prompt-title {
      font-size: 2.5rem;
      margin-bottom: 8px;
      color: hsl(var(--text-primary));
    }

    .category-meta {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 24px;
    }

    .badge {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 9999px;
      letter-spacing: 0.05em;
    }

    .category-badge {
      background: rgba(37, 99, 235, 0.08);
      color: hsl(var(--primary));
      border: 1px solid rgba(37, 99, 235, 0.2);
    }

    .meta-label {
      font-size: 0.85rem;
      color: hsl(var(--text-muted));
    }

    /* Output preview layout */
    .image-preview-container {
      position: relative;
      padding: 16px;
      border-radius: 16px;
      margin-bottom: 32px;
      overflow: hidden;
      display: flex;
      justify-content: center;
      background: hsl(var(--bg-surface));
      border: 1px solid hsl(var(--border));
    }

    .image-preview {
      max-width: 100%;
      max-height: 500px;
      border-radius: 12px;
      object-fit: contain;
      z-index: 1;
      transition: var(--transition-smooth);
    }

    .image-preview-container:hover .image-preview {
      transform: scale(1.015);
    }

    .glow-layer {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at center, rgba(37, 99, 235, 0.04) 0%, transparent 70%);
      pointer-events: none;
    }

    /* Console styled box */
    .prompt-console {
      padding: 0;
      border-radius: 12px;
      overflow: hidden;
      background: hsl(var(--bg-surface));
      border: 1px solid hsl(var(--border));
    }

    .console-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 20px;
      background: rgba(0, 0, 0, 0.02);
      border-bottom: 1px solid hsl(var(--border));
    }

    .console-title {
      font-size: 0.9rem;
      font-weight: 600;
      color: hsl(var(--text-secondary));
    }

    .btn-copy {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #ffffff;
      border: 1px solid hsl(var(--border));
      color: hsl(var(--text-primary));
      font-family: inherit;
      font-size: 0.85rem;
      font-weight: 500;
      padding: 6px 12px;
      border-radius: 6px;
      cursor: pointer;
      transition: var(--transition-smooth);
    }

    .btn-copy:hover {
      background: rgba(37, 99, 235, 0.08);
      border-color: rgba(37, 99, 235, 0.2);
      color: hsl(var(--primary));
    }

    .console-body {
      padding: 24px;
    }

    .prompt-code-block {
      margin: 0;
      white-space: pre-wrap;
      word-break: break-word;
      font-family: 'Courier New', Courier, monospace;
      font-size: 1.05rem;
      color: hsl(var(--text-primary));
      line-height: 1.5;
    }

    /* Sidebar styles */
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .widget-extension {
      border: 1px solid rgba(37, 99, 235, 0.15);
      background: radial-gradient(circle at top right, rgba(37, 99, 235, 0.03), transparent 70%), var(--glass-bg);
    }

    .widget-extension h3 {
      font-size: 1.35rem;
      color: hsl(var(--text-primary));
      margin-bottom: 8px;
    }

    .widget-desc {
      font-size: 0.95rem;
      color: hsl(var(--text-secondary));
      margin-bottom: 20px;
    }

    .widget-features {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 24px;
    }

    .feature-item {
      display: flex;
      gap: 10px;
      font-size: 0.9rem;
      color: hsl(var(--text-primary));
    }

    .feature-bullet {
      color: hsl(var(--primary));
      font-weight: bold;
    }

    .install-btn {
      width: 100%;
      gap: 8px;
    }

    .chrome-icon {
      flex-shrink: 0;
    }

    /* Tag styles */
    .widget-tags h4, .widget-similar h4 {
      font-size: 1.1rem;
      color: hsl(var(--text-primary));
      margin-bottom: 16px;
      border-bottom: 1px solid hsl(var(--border));
      padding-bottom: 8px;
    }

    .tags-cloud {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .tag-badge {
      background: hsl(var(--bg-surface));
      border: 1px solid hsl(var(--border));
      color: hsl(var(--text-secondary));
      font-size: 0.85rem;
      padding: 4px 10px;
      border-radius: 6px;
    }

    /* Similar items list */
    .similar-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .similar-item {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: 12px;
      border-radius: 8px;
      background: hsl(var(--bg-surface));
      border: 1px solid hsl(var(--border));
      text-decoration: none;
      transition: var(--transition-smooth);
    }

    .similar-item:hover {
      border-color: rgba(37, 99, 235, 0.2);
      background: rgba(37, 99, 235, 0.02);
      transform: translateY(-1px);
    }

    .similar-title {
      font-weight: 500;
      color: hsl(var(--text-primary));
      font-size: 0.95rem;
    }

    .similar-meta {
      font-size: 0.8rem;
      color: hsl(var(--text-muted));
    }
  </style>

  <!-- Client-Side Copy Script -->
  <script>
    const copyBtn = document.getElementById('copy-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        const text = copyBtn.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(text).then(() => {
          const btnText = copyBtn.querySelector('.btn-text');
          const originalText = btnText ? btnText.textContent : 'Copy Prompt';
          
          if (btnText) {
            btnText.textContent = 'Copied!';
          }
          copyBtn.style.transform = 'scale(0.95)';
          copyBtn.style.borderColor = 'hsl(var(--success))';
          copyBtn.style.color = '#10b981';
          
          setTimeout(() => {
            if (btnText) {
              btnText.textContent = originalText;
            }
            copyBtn.style.transform = 'none';
            copyBtn.style.borderColor = 'hsl(var(--border))';
            copyBtn.style.color = 'hsl(var(--text-primary))';
          }, 2000);
        }).catch(err => {
          console.error('Copy failed:', err);
        });
      });
    }
  </script>
</BaseLayout>
