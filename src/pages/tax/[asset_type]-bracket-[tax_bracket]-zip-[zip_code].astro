---
// src/pages/tax/[asset_type]-bracket-[tax_bracket]-zip-[zip_code].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import taxData from '../../data/tax_calculators.json';

export async function getStaticPaths() {
  return taxData.map((item) => ({
    params: {
      asset_type: item.asset_type.toLowerCase().replace(/\s+/g, '-'),
      tax_bracket: item.tax_bracket.replace(/%/g, ''),
      zip_code: item.zip_code,
    },
    props: { item },
  }));
}

const { item } = Astro.props;

const pageTitle = `Marginal Tax Calculator for ${item.asset_type} (${item.tax_bracket} Bracket, Zip ${item.zip_code})`;
const pageDesc = `Compute dynamic tax liability. Current model values for ${item.asset_type} assets in the ${item.tax_bracket} marginal bracket for region ${item.region}.`;

// Dynamic Related Links Matrix
const relatedCalculators = taxData.filter(other => 
  other.id !== item.id && 
  (other.asset_type === item.asset_type || 
   other.tax_bracket === item.tax_bracket)
);

// Build dynamic FAQ schema graph
const faqLd = {
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What is the tax rate for ${item.asset_type} in Zip ${item.zip_code}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `For ${item.asset_type} assets in zip code ${item.zip_code} (${item.region}), the base tax rate is ${(item.base_rate * 100).toFixed(1)}% with a local surcharge of ${(item.local_surcharge * 100).toFixed(1)}%.`
      }
    },
    {
      "@type": "Question",
      "name": `What tax deductions are available for ${item.asset_type} in this bracket?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Common deduction offsets for ${item.asset_type} assets include: ${item.deductions_available}.`
      }
    }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FinancialCalculator",
      "name": pageTitle,
      "description": pageDesc,
      "category": "TaxCalculator",
      "offers": {
        "@type": "Offer",
        "price": "0.00",
        "priceCurrency": "USD"
      }
    },
    faqLd
  ]
};
---

<BaseLayout title={pageTitle} description={pageDesc} jsonLd={jsonLd}>
  <div class="calculator-header">
    <h1>Tax Valuation Engine</h1>
    <p class="subtitle">Asset-specific estimation formula for region: <strong>{item.region} (Zip {item.zip_code})</strong></p>
  </div>

  <div class="layout-split">
    <!-- Calculator Card Form -->
    <div class="card-glass flex-column">
      <h2>Marginal Liability Estimator</h2>
      
      <div class="calculator-inputs">
        <div class="form-group">
          <label for="asset-value">Current Asset Market Value ($)</label>
          <input type="number" id="asset-value" class="input-field" value="250000" min="0" step="1000">
        </div>
        
        <div class="form-group">
          <label for="deductions-apply">Apply Standard Deductions ($)</label>
          <input type="number" id="deductions-apply" class="input-field" value="10000" min="0" step="500">
        </div>
      </div>

      <div class="outputs-panel">
        <div class="output-item">
          <span>Est. Base Tax Rate</span>
          <strong id="out-base-rate">{(item.base_rate * 100).toFixed(1)}%</strong>
        </div>
        <div class="output-item">
          <span>Local Surcharge Rate</span>
          <strong id="out-surcharge">{(item.local_surcharge * 100).toFixed(1)}%</strong>
        </div>
        <div class="output-item total">
          <span>Estimated Annual Liability</span>
          <strong id="out-total-liability">$0.00</strong>
        </div>
      </div>

      <div class="deduction-info">
        <h3>Available Deductions for {item.asset_type}</h3>
        <p>{item.deductions_available}</p>
        <p class="entity-recommend">Recommended Entity Structure: <strong>{item.recommended_entity}</strong></p>
      </div>

      <!-- FAQ Accordion section -->
      <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        
        <div class="faq-accordion">
          <button class="faq-toggle">
            How are calculations performed for {item.asset_type}?
            <svg class="arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="faq-panel">
            <p>Calculations take your asset market value, subtract any deductions, and apply the marginal tax rate of <strong>{(item.base_rate * 100).toFixed(1)}%</strong>, along with any local regional zip code surcharges of <strong>{(item.local_surcharge * 100).toFixed(1)}%</strong>.</p>
          </div>
        </div>

        <div class="faq-accordion">
          <button class="faq-toggle">
            What is the entity structural recommendation for Zip {item.zip_code}?
            <svg class="arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="faq-panel">
            <p>For operations involving {item.asset_type} in {item.region}, standard tax planning strategies commonly recommend a <strong>{item.recommended_entity}</strong> setup to isolate liabilities and write off deductions.</p>
          </div>
        </div>
      </div>

      <div class="action-row">
        <button class="btn-primary" id="btn-recalc">Re-Calculate</button>
        <button class="btn-secondary" id="btn-share-tax">Copy Calculation Link</button>
      </div>
    </div>

    <!-- Ad & Compliance Section -->
    <div class="sidebar-container">
      <div class="ad-placement-box">
        <span class="ad-badge">Advertisement</span>
        <div class="ad-stub-frame" id="ad-frame-tax">
          Financial Advisory Solutions Loading...
        </div>
      </div>

      <div class="card-glass stats-panel">
        <h3>Regional Stat Profiles</h3>
        <p>Representative average valuation in Zip {item.zip_code}: <strong>{item.average_valuation}</strong></p>
      </div>
    </div>
  </div>

  <!-- Dynamic Related Links Grid (Prevents Orphans) -->
  {relatedCalculators.length > 0 && (
    <div class="related-matrix card-glass">
      <h3>Alternative Regional Estimators</h3>
      <p class="section-desc">Tax calculation models based on adjacent asset brackets and locations:</p>
      <div class="related-grid">
        {relatedCalculators.map((other) => {
          const asset = other.asset_type.toLowerCase().replace(/\s+/g, '-');
          const bracket = other.tax_bracket.replace(/%/g, '');
          return (
            <a href={`/tax/${asset}-bracket-${bracket}-zip-${other.zip_code}`} class="related-card-link">
              <span>{other.asset_type} ({other.tax_bracket})</span>
              <span class="related-meta">Zip: {other.zip_code} | {other.region}</span>
            </a>
          );
        })}
      </div>
    </div>
  )}

  <style>
    .flex-column {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .calculator-inputs {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
    }

    @media (min-width: 768px) {
      .calculator-inputs {
        grid-template-columns: 1fr 1fr;
      }
    }

    .outputs-panel {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid hsl(var(--border));
      border-radius: 12px;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .output-item {
      display: flex;
      justify-content: space-between;
      color: hsl(var(--text-secondary));
    }

    .output-item.total {
      border-top: 1px solid hsl(var(--border));
      padding-top: 12px;
      margin-top: 4px;
      color: #fff;
      font-size: 1.125rem;
    }

    .output-item.total strong {
      color: hsl(var(--primary));
      font-size: 1.25rem;
    }

    .deduction-info {
      background: rgba(142, 70, 45, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.04);
      border-radius: 8px;
      padding: 16px;
      font-size: 0.95rem;
    }

    .deduction-info h3 {
      font-size: 1rem;
      margin-bottom: 8px;
    }

    .entity-recommend {
      margin-top: 8px;
      color: hsl(var(--text-secondary));
    }

    /* FAQ accordion styling */
    .faq-section {
      border-top: 1px solid hsl(var(--border));
      padding-top: 24px;
    }

    .faq-section h2 {
      font-size: 1.25rem;
      margin-bottom: 16px;
      color: #fff;
    }

    .faq-accordion {
      border: 1px solid hsl(var(--border));
      border-radius: 8px;
      margin-bottom: 12px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.01);
    }

    .faq-toggle {
      width: 100%;
      background: transparent;
      border: none;
      padding: 16px 20px;
      text-align: left;
      font-family: inherit;
      font-size: 1rem;
      font-weight: 500;
      color: #fff;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: var(--transition-smooth);
    }

    .faq-toggle:hover {
      background: rgba(255, 255, 255, 0.03);
    }

    .faq-toggle .arrow {
      transition: transform 0.2s ease;
      color: hsl(var(--text-secondary));
    }

    .faq-panel {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      background: rgba(15, 23, 42, 0.2);
    }

    .faq-panel p {
      padding: 16px 20px;
      font-size: 0.95rem;
      color: hsl(var(--text-secondary));
      line-height: 1.6;
    }

    .faq-accordion.active .faq-panel {
      max-height: 150px;
    }

    .faq-accordion.active .arrow {
      transform: rotate(180deg);
      color: hsl(var(--primary));
    }

    .action-row {
      display: flex;
      gap: 12px;
    }

    .sidebar-container {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    /* Related Matrix styles */
    .related-matrix {
      margin-top: 40px;
      padding: 24px;
    }

    .related-matrix h3 {
      font-size: 1.25rem;
      color: #fff;
      margin-bottom: 6px;
    }

    .related-matrix .section-desc {
      color: hsl(var(--text-secondary));
      font-size: 0.9rem;
      margin-bottom: 16px;
    }

    .related-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }

    @media (min-width: 768px) {
      .related-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .related-card-link {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid hsl(var(--border));
      border-radius: 8px;
      padding: 16px;
      text-decoration: none;
      color: #fff;
      display: flex;
      flex-direction: column;
      gap: 4px;
      transition: var(--transition-smooth);
    }

    .related-card-link:hover {
      border-color: hsl(var(--primary));
      background: rgba(14, 165, 233, 0.04);
      transform: translateY(-2px);
    }

    .related-card-link span {
      font-weight: 600;
    }

    .related-card-link .related-meta {
      font-size: 0.8rem;
      color: hsl(var(--text-secondary));
    }
  </style>

  <script define:vars={{ baseRate: item.base_rate, localSurcharge: item.local_surcharge }}>
    // FAQ toggles
    const toggles = document.querySelectorAll('.faq-toggle');
    toggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        const accordion = toggle.parentElement;
        if (accordion) {
          accordion.classList.toggle('active');
        }
      });
    });

    // Calculation Logic
    const assetInput = document.getElementById('asset-value');
    const deductionInput = document.getElementById('deductions-apply');
    const outTotal = document.getElementById('out-total-liability');
    const btnRecalc = document.getElementById('btn-recalc');

    function calculate() {
      const val = parseFloat(assetInput.value) || 0;
      const dec = parseFloat(deductionInput.value) || 0;
      
      const taxable = Math.max(0, val - dec);
      const totalRate = baseRate + localSurcharge;
      const totalTax = taxable * totalRate;

      outTotal.textContent = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD'
      }).format(totalTax);
    }

    // Bind events
    btnRecalc.addEventListener('click', calculate);
    assetInput.addEventListener('input', calculate);
    deductionInput.addEventListener('input', calculate);

    // Initial load calculation run
    calculate();

    // Share link interaction
    const btnShare = document.getElementById('btn-share-tax');
    if (btnShare) {
      btnShare.addEventListener('click', () => {
        navigator.clipboard.writeText(window.location.href);
        btnShare.textContent = 'Link Copied!';
        setTimeout(() => {
          btnShare.textContent = 'Copy Calculation Link';
        }, 2000);
      });
    }

    // Lazy load ad refresh loop implementation
    let activeTime = 0;
    const adFrame = document.getElementById('ad-frame-tax');

    setInterval(() => {
      activeTime += 15;
      if (activeTime >= 45) {
        activeTime = 0;
        if (adFrame) {
          adFrame.style.opacity = '0.3';
          setTimeout(() => {
            adFrame.textContent = 'Premium Financial Auditing Tools [Refreshed]';
            adFrame.style.opacity = '1';
          }, 400);
        }
      }
    }, 15000);
  </script>
</BaseLayout>
