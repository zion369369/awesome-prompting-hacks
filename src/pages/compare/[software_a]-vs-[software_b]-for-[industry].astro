---
// src/pages/compare/[software_a]-vs-[software_b]-for-[industry].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import saasData from '../../data/saas_comparisons.json';

export async function getStaticPaths() {
  return saasData.map((item) => ({
    params: {
      software_a: item.software_a.toLowerCase().replace(/\s+/g, '-'),
      software_b: item.software_b.toLowerCase().replace(/\s+/g, '-'),
      industry: item.industry.toLowerCase().replace(/\s+/g, '-'),
    },
    props: { item },
  }));
}

const { item } = Astro.props;

const pageTitle = `${item.software_a} vs ${item.software_b} for ${item.industry} (${new Date().getFullYear()} Comparison)`;
const pageDesc = `Detailed programmatic comparison: ${item.software_a} vs ${item.software_b} specifically designed for ${item.industry} businesses. Review features, pros, cons, and pricing.`;

// Dynamic Related Links Matrix
const relatedComparisons = saasData.filter(other => 
  other.id !== item.id && 
  (other.industry === item.industry || 
   other.software_a === item.software_a || 
   other.software_b === item.software_b)
);

// Build structured metadata (ProductCompareSection + FAQPage)
const faqLd = {
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Is ${item.software_a} or ${item.software_b} better for ${item.industry}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `For ${item.industry}, ${item.cheaper_option} is typically recommended due to its efficiency and pricing index. ${item.software_a} offers ${item.best_feature_a}, while ${item.software_b} stands out with ${item.best_feature_b}.`
      }
    },
    {
      "@type": "Question",
      "name": `How long does it take to set up ${item.software_a} or ${item.software_b} in ${item.industry}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The estimated onboarding and setup timeline is approximately ${item.setup_time} for deployment.`
      }
    }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProductCompareSection",
      "name": pageTitle,
      "description": pageDesc,
      "about": [
        {
          "@type": "SoftwareApplication",
          "name": item.software_a,
          "applicationCategory": "BusinessApplication"
        },
        {
          "@type": "SoftwareApplication",
          "name": item.software_b,
          "applicationCategory": "BusinessApplication"
        }
      ],
      "offers": {
        "@type": "AggregateOffer",
        "priceCurrency": "USD",
        "lowPrice": item.average_pricing_b,
        "highPrice": item.average_pricing_a
      }
    },
    faqLd
  ]
};
---

<BaseLayout title={pageTitle} description={pageDesc} jsonLd={jsonLd}>
  <div class="comparison-header">
    <h1>{item.software_a} <span>vs</span> {item.software_b}</h1>
    <p class="subtitle">An objective technical comparison specifically compiled for the <strong>{item.industry}</strong> sector.</p>
  </div>

  <div class="layout-split">
    <!-- Main Comparison Matrix Column -->
    <div class="card-glass flex-column">
      <div class="comparison-matrix-header">
        <h2>Comparison Summary Matrix</h2>
        <p>Dynamic assessment index score: <strong>{item.difficulty_score}/10</strong></p>
      </div>

      <div class="comparison-grid-body">
        <div class="metric-row">
          <div class="metric-label">Estimated Setup Time</div>
          <div class="metric-val">{item.setup_time}</div>
        </div>
        <div class="metric-row">
          <div class="metric-label">Market Adoption Share</div>
          <div class="metric-val">{item.market_share}</div>
        </div>
        <div class="metric-row">
          <div class="metric-label">Estimated Average Pricing</div>
          <div class="metric-val-split">
            <div><strong>{item.software_a}:</strong> {item.average_pricing_a}</div>
            <div><strong>{item.software_b}:</strong> {item.average_pricing_b}</div>
          </div>
        </div>
      </div>

      <div class="feature-analysis">
        <div class="feature-block">
          <h3>Best for {item.industry} ({item.software_a})</h3>
          <p>{item.best_feature_a}</p>
        </div>
        <div class="feature-block">
          <h3>Best for {item.industry} ({item.software_b})</h3>
          <p>{item.best_feature_b}</p>
        </div>
      </div>

      <!-- FAQ Accordions (Dynamic PAA targets) -->
      <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-accordion">
          <button class="faq-toggle">
            Is {item.software_a} or {item.software_b} better for {item.industry}?
            <svg class="arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="faq-panel">
            <p>For operations in the {item.industry} sector, <strong>{item.cheaper_option}</strong> is generally recommended due to pricing efficiency. {item.software_a} offers unique advantages in <em>{item.best_feature_a}</em>, while {item.software_b} specializes in <em>{item.best_feature_b}</em>.</p>
          </div>
        </div>
        
        <div class="faq-accordion">
          <button class="faq-toggle">
            What is the typical setup timeline in {item.industry}?
            <svg class="arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="faq-panel">
            <p>On average, organizations deploying these tools in {item.industry} report a setup phase of <strong>{item.setup_time}</strong> from initial database configuration to team rollout.</p>
          </div>
        </div>
      </div>

      <div class="decision-box">
        <h3>Primary Valuation Recommendation</h3>
        <p>For operations targeting efficiency in {item.industry}, the recommended option is <strong>{item.cheaper_option}</strong> due to lower total cost of ownership (TCO) and rapid onboarding pipelines.</p>
        
        <div class="action-row">
          <button class="btn-primary" id="btn-export">
            Export Clean PDF Report
          </button>
          <button class="btn-secondary" id="btn-copy">
            Copy URL Link
          </button>
        </div>
      </div>
    </div>

    <!-- Sidebar: Ad unit & Pros/Cons -->
    <div class="sidebar-container">
      <div class="ad-placement-box">
        <span class="ad-badge">Advertisement</span>
        <div class="ad-stub-frame" id="ad-frame-1">
          Responsive Ads Loading...
        </div>
      </div>
      
      <div class="pros-cons-container card-glass">
        <h3>Critical Limitations</h3>
        <div class="side-panel-info">
          <h4>{item.software_a} Drawback:</h4>
          <p class="cons-text">{item.cons_a}</p>
          <h4>{item.software_b} Drawback:</h4>
          <p class="cons-text">{item.cons_b}</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Dynamic Related Page Links Grid (Prevents Orphans, Distributes Link Weight) -->
  {relatedComparisons.length > 0 && (
    <div class="related-matrix card-glass">
      <h3>Related Comparative Evaluations</h3>
      <p class="section-desc">Further assessment reports matching your product and industry selections:</p>
      <div class="related-grid">
        {relatedComparisons.map((other) => {
          const sa = other.software_a.toLowerCase().replace(/\s+/g, '-');
          const sb = other.software_b.toLowerCase().replace(/\s+/g, '-');
          const ind = other.industry.toLowerCase().replace(/\s+/g, '-');
          return (
            <a href={`/compare/${sa}-vs-${sb}-for-${ind}`} class="related-card-link">
              <span>{other.software_a} vs {other.software_b}</span>
              <span class="related-meta">Industry: {other.industry}</span>
            </a>
          );
        })}
      </div>
    </div>
  )}

  <style>
    .comparison-header h1 span {
      color: hsl(var(--primary));
    }
    
    .flex-column {
      display: flex;
      flex-direction: column;
      gap: 28px;
    }

    .comparison-matrix-header {
      border-bottom: 1px solid hsl(var(--border));
      padding-bottom: 16px;
    }

    .comparison-grid-body {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .metric-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 16px;
      background: rgba(255, 255, 255, 0.02);
      border-radius: 8px;
      border: 1px solid hsl(var(--border));
    }

    .metric-label {
      font-weight: 500;
      color: hsl(var(--text-secondary));
    }

    .metric-val {
      font-weight: 600;
      color: hsl(var(--primary));
    }

    .metric-val-split {
      text-align: right;
      font-size: 0.9rem;
    }

    .feature-analysis {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
    }

    @media (min-width: 768px) {
      .feature-analysis {
        grid-template-columns: 1fr 1fr;
      }
    }

    .feature-block {
      background: rgba(14, 165, 233, 0.03);
      border: 1px solid rgba(14, 165, 233, 0.08);
      border-radius: 8px;
      padding: 16px;
    }

    .feature-block h3 {
      font-size: 1rem;
      margin-bottom: 8px;
      color: #fff;
    }

    /* FAQ accordion styling */
    .faq-section {
      border-top: 1px solid hsl(var(--border));
      padding-top: 24px;
    }

    .faq-section h2 {
      font-size: 1.25rem;
      margin-bottom: 16px;
      color: #fff;
    }

    .faq-accordion {
      border: 1px solid hsl(var(--border));
      border-radius: 8px;
      margin-bottom: 12px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.01);
    }

    .faq-toggle {
      width: 100%;
      background: transparent;
      border: none;
      padding: 16px 20px;
      text-align: left;
      font-family: inherit;
      font-size: 1rem;
      font-weight: 500;
      color: #fff;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: var(--transition-smooth);
    }

    .faq-toggle:hover {
      background: rgba(255, 255, 255, 0.03);
    }

    .faq-toggle .arrow {
      transition: transform 0.2s ease;
      color: hsl(var(--text-secondary));
    }

    .faq-panel {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      background: rgba(15, 23, 42, 0.2);
    }

    .faq-panel p {
      padding: 16px 20px;
      font-size: 0.95rem;
      color: hsl(var(--text-secondary));
      line-height: 1.6;
    }

    .faq-accordion.active .faq-panel {
      max-height: 150px;
    }

    .faq-accordion.active .arrow {
      transform: rotate(180deg);
      color: hsl(var(--primary));
    }

    .decision-box {
      border-top: 1px solid hsl(var(--border));
      padding-top: 24px;
    }

    .decision-box h3 {
      margin-bottom: 8px;
    }

    .action-row {
      display: flex;
      gap: 12px;
      margin-top: 20px;
    }

    .btn-secondary {
      background: transparent;
      color: #fff;
      border: 1px solid hsl(var(--border));
      border-radius: 8px;
      padding: 14px 28px;
      font-family: inherit;
      font-weight: 500;
      cursor: pointer;
      transition: var(--transition-smooth);
    }

    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.05);
      border-color: hsl(var(--text-secondary));
    }

    .sidebar-container {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .side-panel-info h4 {
      margin-top: 12px;
      font-size: 0.95rem;
      color: #fff;
    }

    .cons-text {
      font-size: 0.9rem;
      color: hsl(var(--text-secondary));
      margin-bottom: 12px;
    }

    /* Related Matrix styles */
    .related-matrix {
      margin-top: 40px;
      padding: 24px;
    }

    .related-matrix h3 {
      font-size: 1.25rem;
      color: #fff;
      margin-bottom: 6px;
    }

    .related-matrix .section-desc {
      color: hsl(var(--text-secondary));
      font-size: 0.9rem;
      margin-bottom: 16px;
    }

    .related-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }

    @media (min-width: 768px) {
      .related-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .related-card-link {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid hsl(var(--border));
      border-radius: 8px;
      padding: 16px;
      text-decoration: none;
      color: #fff;
      display: flex;
      flex-direction: column;
      gap: 4px;
      transition: var(--transition-smooth);
    }

    .related-card-link:hover {
      border-color: hsl(var(--primary));
      background: rgba(14, 165, 233, 0.04);
      transform: translateY(-2px);
    }

    .related-card-link span {
      font-weight: 600;
    }

    .related-card-link .related-meta {
      font-size: 0.8rem;
      color: hsl(var(--text-secondary));
    }
  </style>

  <script>
    // FAQ accordion toggles
    const toggles = document.querySelectorAll('.faq-toggle');
    toggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        const accordion = toggle.parentElement;
        if (accordion) {
          accordion.classList.toggle('active');
        }
      });
    });

    // Share & Copy interactions
    const btnCopy = document.getElementById('btn-copy');
    if (btnCopy) {
      btnCopy.addEventListener('click', () => {
        navigator.clipboard.writeText(window.location.href);
        btnCopy.textContent = 'Copied!';
        setTimeout(() => {
          btnCopy.textContent = 'Copy URL Link';
        }, 2000);
      });
    }

    const btnExport = document.getElementById('btn-export');
    if (btnExport) {
      btnExport.addEventListener('click', () => {
        alert('Compiling download package... Complete.');
      });
    }

    // Lazy load ad refresh loop
    let activeTime = 0;
    const adFrame = document.getElementById('ad-frame-1');

    setInterval(() => {
      activeTime += 15;
      if (activeTime >= 45) {
        activeTime = 0;
        if (adFrame) {
          adFrame.style.opacity = '0.3';
          setTimeout(() => {
            adFrame.textContent = 'Relevant Business Solutions [Refreshed]';
            adFrame.style.opacity = '1';
          }, 400);
        }
      }
    }, 15000);
  </script>
</BaseLayout>
