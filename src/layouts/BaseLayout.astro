---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import seoConfig from '../../config/seo.json';
import { SEO } from 'astro-seo';

interface Props {
  title: string;
  description: string;
  image?: string;
  jsonLd?: Record<string, any>;
}

const { title, description, image, jsonLd } = Astro.props;
const canonicalUrl = Astro.url.href;

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

// Build absolute OG image path
const ogImage = image
  ? (image.startsWith('http') ? image : new URL(baseUrl + image.replace(/^\//, ''), Astro.url).href)
  : new URL(baseUrl + 'og-image.png', Astro.url).href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="llms-txt" href="https://zion369369.github.io/awesome-prompting-hacks/llms.txt" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="shortcut icon" href={`${baseUrl}favicon.ico`} sizes="any" />
    
    <!-- Preconnect & Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    
    <SEO
      title={title}
      description={description}
      canonical={canonicalUrl}
      openGraph={{
        basic: {
          title: title,
          type: "website",
          image: ogImage,
          url: canonicalUrl,
        },
        optional: {
          siteName: "Awesome Prompting Hacks",
          locale: "en_US",
          description: description,
        }
      }}
      twitter={{
        card: "summary_large_image",
        title: title,
        description: description,
        image: ogImage,
      }}
      extend={{
        meta: [
          { name: "robots", content: "index, follow" },
          { name: "generator", content: Astro.generator },
          ...(seoConfig.google_site_verification ? [{ name: "google-site-verification", content: seoConfig.google_site_verification }] : [])
        ]
      }}
    />
    
    <!-- Inline Dynamic JSON-LD structured schema block -->
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <div class="app-container">
      <header>
        <div class="header-inner">
          <a href={baseUrl} class="logo">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 17 10 11 4 5"></polyline>
              <line x1="12" y1="19" x2="20" y2="19"></line>
            </svg>
            <span>Awesome Prompting Hacks</span>
          </a>
        </div>
      </header>

      <main class="main-content">
        <slot />
      </main>

      <footer>
        <div class="footer-inner">
          <p>&copy; {new Date().getFullYear()} Awesome Prompting Hacks. All prompt templates are community resources.</p>
          <div class="footer-links">
            <a href={`${baseUrl}directory/1`}>Prompt Directory</a>
            <a href={`${baseUrl}privacy`}>Privacy Policy</a>
            <a href={`${baseUrl}terms`}>Terms of Service</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
